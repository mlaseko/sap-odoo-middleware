@page "/documents/{id:guid}"
@model SapOdooMiddleware.Pages.Documents.DetailModel
@{
    var badge = Model.ValidationBadge();
}

<div style="display:flex; justify-content:space-between; align-items:center;">
    <h2 style="margin:0;">@(Model.Doc.InvoiceNumber ?? Model.Doc.OriginalFilename)</h2>
    <a href="/documents">← Back to list</a>
</div>

<div id="progress-card" class="progress-card" style="display:none">
    <div class="progress-header">
        <span class="progress-label">Extracting…</span>
        <span class="progress-page-text">Page <span id="pp-current">0</span> of <span id="pp-total">0</span></span>
    </div>
    <div class="progress-bar-track">
        <div class="progress-bar-fill" id="pp-fill" style="width: 0%"></div>
    </div>
    <div class="progress-meta">
        <span id="pp-percent">0%</span>
        <span id="pp-elapsed"></span>
        <span id="pp-eta"></span>
    </div>
</div>

<div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            Status: <strong>@Model.Doc.Status</strong>
            &nbsp;|&nbsp; Validation: <span class="badge @badge.Css">@badge.Text</span>
        </div>
        <div>@Model.Doc.PageCount page(s)</div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Doc.ValidationNotes))
    {
        <p style="margin:8px 0 0; color:#854d0e;">@Model.Doc.ValidationNotes</p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Doc.ErrorMessage))
    {
        <p style="margin:8px 0 0; color:#991b1b;">@Model.Doc.ErrorMessage</p>
    }
</div>

<div class="card">
    <table>
        <tbody>
            <tr><th>Invoice number</th><td>@Model.Doc.InvoiceNumber</td>
                <th>Invoice date</th><td>@(Model.Doc.InvoiceDate?.ToString("yyyy-MM-dd"))</td></tr>
            <tr><th>Customer</th><td>@Model.Doc.CustomerName</td>
                <th>Customer account</th><td>@Model.Doc.CustomerAccount</td></tr>
            <tr><th>Sales order</th><td>@Model.Doc.SalesOrder</td>
                <th>Delivery note</th><td>@Model.Doc.DeliveryNoteRef</td></tr>
            <tr><th>Currency</th><td>@Model.Doc.Currency</td>
                <th>Payment terms</th><td>@Model.Doc.PaymentTerms</td></tr>
            <tr><th>Subtotal</th><td class="num">@(Model.Doc.Subtotal?.ToString("N2"))</td>
                <th>Freight</th><td class="num">@(Model.Doc.Freight?.ToString("N2"))</td></tr>
            <tr><th>Total net</th><td class="num">@(Model.Doc.TotalNet?.ToString("N2"))</td>
                <th>Invoice total</th><td class="num">@(Model.Doc.InvoiceTotal?.ToString("N2"))</td></tr>
        </tbody>
    </table>
</div>

<h3>Line items (@Model.Lines.Count)</h3>
<table>
    <thead>
        <tr>
            <th class="num">#</th>
            <th>Article</th>
            <th>Description</th>
            <th>Pack</th>
            <th>Unit</th>
            <th class="num">Qty</th>
            <th class="num">Unit price</th>
            <th class="num">Line total</th>
            <th class="num">Disc %</th>
            <th>Origin</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in Model.Lines)
    {
        <tr class="@(l.IsPromotional ? "promo" : null)">
            <td class="num">@l.LineNo</td>
            <td>@l.ArticleNumber @(l.IsPromotional ? "(Promo)" : null)</td>
            <td>@l.Description</td>
            <td>@l.PackSize</td>
            <td>@l.Unit</td>
            <td class="num">@(l.Quantity?.ToString("0.###"))</td>
            <td class="num">@(l.UnitPrice?.ToString("N2"))</td>
            <td class="num">@(l.LineTotal?.ToString("N2"))</td>
            <td class="num">@l.DiscountPct.ToString("0.##")</td>
            <td>@l.Origin</td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="7" class="num">Σ(line totals) + freight = @Model.ComputedTotal.ToString("N2")</th>
            <th class="num">vs total net @(Model.Doc.TotalNet?.ToString("N2"))</th>
            <th colspan="2"></th>
        </tr>
    </tfoot>
</table>

<script>
(function () {
    const docId = @Json.Serialize(Model.Doc.Id);
    const initialStatus = @Json.Serialize(Model.Doc.Status);
    const ACTIVE_STATUSES = ['uploaded', 'extracting'];

    if (!ACTIVE_STATUSES.includes(initialStatus)) return;

    const card = document.getElementById('progress-card');
    const fill = document.getElementById('pp-fill');
    const current = document.getElementById('pp-current');
    const total = document.getElementById('pp-total');
    const percent = document.getElementById('pp-percent');
    const elapsed = document.getElementById('pp-elapsed');
    const eta = document.getElementById('pp-eta');

    card.style.display = 'block';

    // Default per-page estimate (seconds) used before we have a real measurement,
    // and as a floor so the first page still shows motion + an ETA.
    const DEFAULT_PAGE_SEC = 60;
    // Cap intra-page fill so the bar never reaches the next page boundary before that
    // page actually completes (avoids overshoot, then a visible "snap back").
    const INTRA_PAGE_CAP = 0.92;

    let pollTimer = null;
    let tickTimer = null;

    // Snapshot of the latest poll, used to interpolate between polls on the local clock.
    let snap = null; // { pageCount, pagesProcessed, expectedSec, pageElapsedAtSnapSec|null, localAnchorMs }

    function fmtSec(s) {
        if (s == null || !isFinite(s) || s < 0) return '';
        s = Math.round(s);
        if (s < 60) return s + 's';
        const m = Math.floor(s / 60);
        return m + 'm ' + (s - m * 60) + 's';
    }

    // Seconds elapsed on the current page right now, anchored to the server clock at the last
    // poll and advanced by the local clock since (skew-free, smooth between polls).
    function pageElapsedNow() {
        if (!snap || snap.pageElapsedAtSnapSec == null) return null;
        return snap.pageElapsedAtSnapSec + (Date.now() - snap.localAnchorMs) / 1000;
    }

    function render() {
        if (!snap) return;
        const { pageCount, pagesProcessed, expectedSec } = snap;
        const elapsedSec = pageElapsedNow();

        // Fractional progress within the page currently being processed.
        let frac = 0;
        if (elapsedSec != null && expectedSec > 0) {
            frac = Math.min(elapsedSec / expectedSec, INTRA_PAGE_CAP);
        }
        const done = pageCount > 0 ? (pagesProcessed + frac) / pageCount : 0;
        const pct = Math.max(0, Math.min(100, done * 100));

        fill.style.width = pct.toFixed(1) + '%';
        percent.textContent = Math.floor(pct) + '%';
        current.textContent = pagesProcessed;
        total.textContent = pageCount;

        elapsed.textContent = elapsedSec != null ? 'page time: ' + fmtSec(elapsedSec) : '';

        // ETA = time left on the current page + full estimate for the pages after it.
        const pagesAfterCurrent = Math.max(0, pageCount - pagesProcessed - (elapsedSec != null ? 1 : 0));
        let remaining = pagesAfterCurrent * expectedSec;
        if (elapsedSec != null) remaining += Math.max(expectedSec - elapsedSec, 0);
        eta.textContent = (pageCount > 0 && remaining > 0) ? 'eta: ' + fmtSec(remaining) : '';
    }

    async function poll() {
        try {
            const r = await fetch('/api/documents/' + docId + '/status', { cache: 'no-store' });
            if (!r.ok) return;
            const s = await r.json();   // snake_case payload (API uses SnakeCaseLower)

            const pageCount = s.page_count || 0;
            const pagesProcessed = s.pages_processed || 0;
            const expectedSec = (s.last_page_duration_sec != null && s.last_page_duration_sec > 0)
                ? Number(s.last_page_duration_sec) : DEFAULT_PAGE_SEC;

            // Server-clock elapsed on the current page (null when between pages).
            let pageElapsedAtSnapSec = null;
            if (s.current_page_started_at_utc && s.server_now_utc) {
                const started = Date.parse(s.current_page_started_at_utc);
                const serverNow = Date.parse(s.server_now_utc);
                if (isFinite(started) && isFinite(serverNow)) {
                    pageElapsedAtSnapSec = Math.max(0, (serverNow - started) / 1000);
                }
            }

            snap = { pageCount, pagesProcessed, expectedSec, pageElapsedAtSnapSec, localAnchorMs: Date.now() };
            render();

            // Stop once the status is terminal, then soft-reload to show lines/header/footer.
            if (!ACTIVE_STATUSES.includes(s.status)) {
                clearInterval(pollTimer);
                clearInterval(tickTimer);
                fill.style.width = '100%';
                percent.textContent = '100%';
                setTimeout(() => location.reload(), 250);
            }
        } catch (e) {
            // Network blip — keep polling.
        }
    }

    pollTimer = setInterval(poll, 1500);
    tickTimer = setInterval(render, 250);   // smooth local interpolation between polls
    poll(); // initial fire
})();
</script>

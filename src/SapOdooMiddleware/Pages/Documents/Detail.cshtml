@page "/documents/{id:guid}"
@using System.Globalization
@model SapOdooMiddleware.Pages.Documents.DetailModel
@{
    var badge = Model.ValidationBadge();
    var counts = Model.Lines.GroupBy(l => l.ReviewStatus).ToDictionary(g => g.Key, g => g.Count());
    int C(string s) => counts.TryGetValue(s, out var n) ? n : 0;
    string Inv(decimal? d) => d?.ToString(CultureInfo.InvariantCulture) ?? "";
}

<div class="page-head">
    <div>
        <h2>@(Model.Doc.InvoiceNumber ?? Model.Doc.OriginalFilename)</h2>
        <div class="sub">@Model.Doc.Supplier</div>
    </div>
    <a class="btn" href="/documents">← Back to list</a>
</div>

@{
    var progressVm = new SapOdooMiddleware.Pages.ExtractionProgressVm(
        Model.Doc.Id, Model.Doc.Status, $"/api/documents/{Model.Doc.Id}/status");
}
<partial name="/Pages/Shared/_ExtractionProgress.cshtml" model="progressVm" />

<div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            Status: <strong>@Model.Doc.Status</strong>
            &nbsp;|&nbsp; Validation: <span class="badge @badge.Css">@badge.Text</span>
        </div>
        <div>@Model.Doc.PageCount page(s)</div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Doc.ValidationNotes))
    {
        <div class="note-warn">@Model.Doc.ValidationNotes</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Doc.ErrorMessage))
    {
        <div class="note-error">@Model.Doc.ErrorMessage</div>
    }
</div>

<div class="card">
    <table>
        <tbody>
            <tr><th>Invoice number</th><td>@Model.Doc.InvoiceNumber</td>
                <th>Invoice date</th><td>@(Model.Doc.InvoiceDate?.ToString("yyyy-MM-dd"))</td></tr>
            <tr><th>Customer</th><td>@Model.Doc.CustomerName</td>
                <th>Customer account</th><td>@Model.Doc.CustomerAccount</td></tr>
            <tr><th>Sales order</th><td>@Model.Doc.SalesOrder</td>
                <th>Delivery note</th><td>@Model.Doc.DeliveryNoteRef</td></tr>
            <tr><th>Currency</th><td>@Model.Doc.Currency</td>
                <th>Payment terms</th><td>@Model.Doc.PaymentTerms</td></tr>
            <tr><th>Subtotal</th><td class="num">@(Model.Doc.Subtotal?.ToString("N2"))</td>
                <th>Freight</th><td class="num">@(Model.Doc.Freight?.ToString("N2"))</td></tr>
            <tr><th>Total net</th><td class="num">@(Model.Doc.TotalNet?.ToString("N2"))</td>
                <th>Invoice total</th><td class="num">@(Model.Doc.InvoiceTotal?.ToString("N2"))</td></tr>
        </tbody>
    </table>
</div>

@if (Model.ShowReview)
{
    <div id="review-banner" class="review-banner" data-doc-id="@Model.Doc.Id" data-editable="@Model.IsEditable.ToString().ToLowerInvariant()">
        <div class="review-counts" id="review-counts">
            📋 Review:
            <span class="rc rc-matched">@C("matched") matched</span> ·
            <span class="rc rc-create">@C("created") created</span> ·
            <span class="rc rc-createnew">@C("create_new") to create</span> ·
            <span class="rc rc-skip">@C("skip") skipped</span> ·
            <span class="rc rc-pending">@C("pending") pending</span> ·
            <span class="rc rc-failed">@C("create_failed") failed</span>
        </div>
        @if (Model.IsClosed)
        {
            <div class="review-actions">
                <span class="review-done">✓ Reviewed by @Model.Doc.ReviewedBy @(Model.Doc.ReviewedAt is { } ra ? "on " + ra.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "") · Purchase Order created — closed</span>
            </div>
        }
        else if (Model.IsReviewed)
        {
            <div class="review-actions">
                <span class="review-done">✓ Reviewed by @Model.Doc.ReviewedBy @(Model.Doc.ReviewedAt is { } ra ? "on " + ra.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "")</span>
                <button id="btn-createpo" class="btn btn-sm btn-primary" type="button">Create PO</button>
            </div>
        }
        else
        {
            <div class="review-actions">
                <button id="btn-automatch" class="btn btn-sm" type="button">Auto-match again</button>
                <button id="btn-markpending" class="btn btn-sm" type="button">Mark all pending as Create New</button>
                <button id="btn-bulkcreate" class="btn btn-sm" type="button">Bulk Create (<span id="cnt-createnew">@(C("create_new") + C("create_failed"))</span>)</button>
                <button id="btn-createpo" class="btn btn-sm" type="button">Create PO</button>
                <button id="btn-complete" class="btn btn-sm btn-primary" type="button">Complete Review</button>
            </div>
        }
    </div>
}

<h3>Line items (@Model.Lines.Count)</h3>
<table id="lines-table">
    <thead>
        <tr>
            <th class="num">#</th>
            <th>Article</th>
            <th>Description</th>
            <th>Pack</th>
            <th>Unit</th>
            <th class="num">Qty</th>
            <th class="num">Unit price</th>
            <th class="num">Line total</th>
            <th class="num">Disc %</th>
            <th>Commodity</th>
            <th>Origin</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in Model.Lines)
    {
        var pill = SapOdooMiddleware.Pages.Documents.DetailModel.LinePill(l.ReviewStatus);
        var ed = Model.IsEditable ? "editable" : "";
        <tr class="line-row @(l.IsPromotional ? "promo" : null)" data-line-id="@l.Id">
            <td class="num">@l.LineNo</td>
            <td class="@ed" data-field="article_number">@l.ArticleNumber</td>
            <td class="@ed" data-field="description">@l.Description</td>
            <td class="@ed" data-field="pack_size">@l.PackSize</td>
            <td class="@ed" data-field="unit">@l.Unit</td>
            <td class="@ed num" data-field="quantity" data-raw="@Inv(l.Quantity)">@(l.Quantity?.ToString("0.###"))</td>
            <td class="@ed num" data-field="unit_price" data-raw="@Inv(l.UnitPrice)">@(l.UnitPrice?.ToString("N2"))</td>
            <td class="@ed num" data-field="line_total" data-raw="@Inv(l.LineTotal)">@(l.LineTotal?.ToString("N2"))</td>
            <td class="@ed num" data-field="discount_pct" data-raw="@l.DiscountPct.ToString(CultureInfo.InvariantCulture)">@l.DiscountPct.ToString("0.##")</td>
            <td class="@ed" data-field="commodity_code">@l.CommodityCode</td>
            <td class="@ed" data-field="origin">@l.Origin</td>
            <td class="status-cell"><span class="pill @pill.Css">@pill.Text</span></td>
            <td class="actions-cell">
                @if (Model.IsEditable)
                {
                    <details class="actions-menu">
                        <summary>⋮</summary>
                        <div class="menu">
                            <button type="button" data-action="match">Match…</button>
                            <button type="button" data-action="create_new">Create New</button>
                            <button type="button" data-action="accept_category">Accept DGX category &amp; create</button>
                            <button type="button" data-action="pick_category">Pick category &amp; create…</button>
                            <button type="button" data-action="skip">Skip</button>
                        </div>
                    </details>
                }
            </td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="13" class="num">
                Σ(line totals) + freight = @Model.ComputedTotal.ToString("N2")
                &nbsp;&nbsp; vs total net @(Model.Doc.TotalNet?.ToString("N2"))
            </th>
        </tr>
    </tfoot>
</table>

@if (Model.ShowReview)
{
    <div id="modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
            <div id="modal-body"></div>
            <div id="modal-actions" class="modal-actions"></div>
        </div>
    </div>
}

<script>
// ---- Phase B: review interactions (only active for editable/extracted documents) ----
(function () {
    const banner = document.getElementById('review-banner');
    if (!banner) return;
    // Reviewed (read-only) docs still get the Purchase Order action; the editing/match/bulk/complete
    // handlers below are wired only when the doc is editable (their buttons don't exist otherwise).
    const editable = banner.dataset.editable === 'true';

    const docId = banner.dataset.docId;
    const base = '/api/documents/' + docId;

    const PILL = {
        matched: ['pill-green', 'matched'], create_new: ['pill-blue', 'create new'],
        skip: ['pill-grey', 'skip'], pending: ['pill-yellow', 'pending'],
        created: ['pill-green', 'created'], create_failed: ['pill-red', 'create failed']
    };

    const API_KEY = document.querySelector('meta[name="api-key"]')?.content || '';

    async function api(method, path, body) {
        const opts = { method, headers: {} };
        if (API_KEY) opts.headers['X-Api-Key'] = API_KEY;
        if (body !== undefined) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
        const r = await fetch(base + path, opts);
        const text = await r.text();
        const json = text ? JSON.parse(text) : null;
        if (!r.ok) throw new Error((json && json.error) || ('HTTP ' + r.status));
        return json;
    }

    // Like api() but for an absolute path (e.g. /api/admin/taxonomy), not under the document base.
    async function apiAbs(method, path, body) {
        const opts = { method, headers: {} };
        if (API_KEY) opts.headers['X-Api-Key'] = API_KEY;
        if (body !== undefined) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
        const r = await fetch(path, opts);
        const text = await r.text();
        const json = text ? JSON.parse(text) : null;
        if (!r.ok) throw new Error((json && json.error) || ('HTTP ' + r.status));
        return json;
    }

    // Resolve a low-confidence line by picking an Odoo category from the loaded taxonomy and creating it.
    async function pickCategoryAndCreate(row, lineId) {
        let tax;
        try { tax = await apiAbs('GET', '/api/admin/taxonomy'); }
        catch (e) { alert('Could not load categories: ' + e.message); return; }
        const cats = (tax && tax.categories) || [];
        if (!cats.length) { alert('No Odoo taxonomy is loaded (set CategoryTaxonomy:FilePath and reload). Use "Match…" or "Accept DGX category" instead.'); return; }
        const options = cats.map(c => '<option value="' + c.external_id + '">' + c.label + '</option>').join('');
        openModal(
            '<h3>Pick Odoo category</h3><p>Assign a category and create this item in SAP + Odoo.</p>' +
            '<select id="cat-select" class="cell-input" style="width:100%">' + options + '</select>',
            [
                { label: 'Cancel', onClick: closeModal },
                {
                    label: 'Create with category', primary: true, onClick: async () => {
                        const sel = document.getElementById('cat-select');
                        const externalId = sel.value;
                        const name = sel.options[sel.selectedIndex].text;
                        mActions.innerHTML = '';
                        mBody.innerHTML = '<h3>Creating…</h3><div class="spinner"></div>';
                        try {
                            const r = await api('POST', '/lines/' + lineId + '/create-with-category',
                                { odoo_category_external_id: externalId, odoo_category_name: name });
                            closeModal();
                            if (r && r.created) applyLine(row, r.line);
                            else { if (r && r.line) applyLine(row, r.line); alert('Create failed: ' + ((r && r.error) || 'unknown')); }
                            await refreshSummary();
                        } catch (e) { closeModal(); alert('Create failed: ' + e.message); }
                    }
                }
            ]);
    }

    // ---- formatting helpers ----
    const num = (v, dp) => (v === null || v === undefined || v === '') ? '' : Number(v).toFixed(dp);
    function fieldDisplay(field, line) {
        switch (field) {
            case 'quantity': return line.quantity == null ? '' : Number(line.quantity).toLocaleString(undefined, { maximumFractionDigits: 3 });
            case 'unit_price': return num(line.unit_price, 2);
            case 'line_total': return num(line.line_total, 2);
            case 'discount_pct': return num(line.discount_pct, 2);
            default: return line[field] ?? '';
        }
    }
    function fieldRaw(field, line) {
        const v = line[field];
        return (v === null || v === undefined) ? '' : String(v);
    }

    function setRowPill(row, status) {
        const [cls, label] = PILL[status] || ['pill-grey', status];
        row.querySelector('.status-cell').innerHTML = '<span class="pill ' + cls + '">' + label + '</span>';
    }

    function applyLine(row, line) {
        row.querySelectorAll('td.editable').forEach(cell => {
            const f = cell.dataset.field;
            cell.textContent = fieldDisplay(f, line);
            if (cell.dataset.raw !== undefined) cell.dataset.raw = fieldRaw(f, line);
        });
        setRowPill(row, line.review_status);
        row.classList.toggle('promo', !!line.is_promotional);
    }

    // ---- review summary banner ----
    async function refreshSummary() {
        let s;
        try { s = await api('GET', '/review-summary'); } catch (e) { return; }
        const b = s.by_status || {};
        document.getElementById('review-counts').innerHTML =
            '📋 Review: <span class="rc">' + (b.matched || 0) + ' matched</span> · ' +
            '<span class="rc">' + (b.created || 0) + ' created</span> · ' +
            '<span class="rc">' + (b.create_new || 0) + ' to create</span> · ' +
            '<span class="rc">' + (b.skip || 0) + ' skipped</span> · ' +
            '<span class="rc">' + (b.pending || 0) + ' pending</span> · ' +
            '<span class="rc">' + (b.create_failed || 0) + ' failed</span>';
        const createN = (b.create_new || 0) + (b.create_failed || 0);   // failed lines are retried by Bulk Create
        const cnt = document.getElementById('cnt-createnew'); if (cnt) cnt.textContent = createN;
        const mp = document.getElementById('btn-markpending'); if (mp) mp.disabled = (b.pending || 0) === 0;
        const bc = document.getElementById('btn-bulkcreate'); if (bc) bc.disabled = createN === 0;
        const cp = document.getElementById('btn-complete'); if (cp) cp.disabled = !s.can_complete;
    }

    // ---- inline editing ----
    let editing = null;
    function beginEdit(cell) {
        if (editing) return;
        const row = cell.closest('tr');
        const field = cell.dataset.field;
        const displayBefore = cell.textContent;
        const editVal = cell.dataset.raw !== undefined ? cell.dataset.raw : cell.textContent.trim();
        editing = cell;
        let done = false;

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'cell-input';
        input.value = editVal;
        cell.textContent = '';
        cell.appendChild(input);
        input.focus();
        input.select();

        const finish = () => { done = true; editing = null; };

        const commit = async () => {
            if (done) return; finish();
            const val = input.value.trim();
            cell.innerHTML = '<span class="cell-spin">…</span>';
            try {
                const updated = await api('PATCH', '/lines/' + row.dataset.lineId, { [field]: val === '' ? null : val });
                if (updated) applyLine(row, updated);
                await refreshSummary();
            } catch (e) {
                alert('Edit failed: ' + e.message);
                cell.textContent = displayBefore; // best-effort revert
            }
        };

        const cancel = () => { if (done) return; finish(); cell.textContent = displayBefore; };

        input.addEventListener('keydown', ev => {
            if (ev.key === 'Enter') { ev.preventDefault(); commit(); }
            else if (ev.key === 'Escape') { ev.preventDefault(); cancel(); }
        });
        input.addEventListener('blur', commit);
    }

    document.querySelectorAll('#lines-table td.editable').forEach(cell => {
        cell.addEventListener('click', () => beginEdit(cell));
    });

    // ---- per-line actions (Match / Create New / Skip) ----
    document.querySelectorAll('#lines-table .actions-menu .menu button').forEach(btn => {
        btn.addEventListener('click', async () => {
            const row = btn.closest('tr');
            const lineId = row.dataset.lineId;
            const action = btn.dataset.action;
            const details = btn.closest('details'); if (details) details.open = false;
            try {
                // Manual-review resolutions for low-confidence-category failures (return {created, line, error}).
                if (action === 'accept_category') {
                    const r = await api('POST', '/lines/' + lineId + '/create-accept-category');
                    if (r && r.created) applyLine(row, r.line);
                    else { if (r && r.line) applyLine(row, r.line); alert('Create failed: ' + ((r && r.error) || 'unknown')); }
                    await refreshSummary();
                    return;
                }
                if (action === 'pick_category') {
                    await pickCategoryAndCreate(row, lineId);
                    return;
                }
                let updated;
                if (action === 'match') {
                    const current = (row.querySelector('[data-field="article_number"]').textContent || '').trim();
                    const sku = prompt('SAP item code to match this line to:', current);
                    if (!sku) return;
                    updated = await api('POST', '/lines/' + lineId + '/match', { sku });
                } else if (action === 'create_new') {
                    updated = await api('POST', '/lines/' + lineId + '/create-new');
                } else if (action === 'skip') {
                    updated = await api('POST', '/lines/' + lineId + '/skip');
                }
                if (updated) applyLine(row, updated);
                await refreshSummary();
            } catch (e) {
                alert('Action failed: ' + e.message);
            }
        });
    });

    // Open the actions menu upward when there isn't room below (last rows), and keep only one open.
    document.querySelectorAll('#lines-table .actions-menu').forEach(details => {
        details.addEventListener('toggle', () => {
            if (!details.open) { details.classList.remove('up'); return; }
            document.querySelectorAll('#lines-table .actions-menu[open]').forEach(o => { if (o !== details) o.open = false; });
            const menu = details.querySelector('.menu'), sum = details.querySelector('summary');
            if (!menu || !sum) return;
            const spaceBelow = window.innerHeight - sum.getBoundingClientRect().bottom;
            details.classList.toggle('up', menu.offsetHeight + 12 > spaceBelow);
        });
    });

    // ---- banner buttons ----
    let lastAutoMatch = 0;
    document.getElementById('btn-automatch')?.addEventListener('click', async (e) => {
        const now = Date.now();
        if (now - lastAutoMatch < 30000) { alert('Please wait a moment before auto-matching again.'); return; }
        lastAutoMatch = now;
        e.target.disabled = true;
        try {
            const r = await api('POST', '/auto-match');
            alert('Auto-match: ' + r.newly_matched + ' newly matched, ' + r.still_pending + ' still pending. Reloading.');
            location.reload();
        } catch (err) { alert('Auto-match failed: ' + err.message); e.target.disabled = false; }
    });

    document.getElementById('btn-markpending')?.addEventListener('click', async (e) => {
        try { await api('POST', '/bulk-mark-pending-as-create-new'); location.reload(); }
        catch (err) { alert('Failed: ' + err.message); }
    });

    // ---- modals ----
    const overlay = document.getElementById('modal-overlay');
    const mBody = document.getElementById('modal-body');
    const mActions = document.getElementById('modal-actions');
    const mDialog = overlay ? overlay.querySelector('.modal') : null;
    // Set true by any user edit inside the modal, so we can warn before an accidental close.
    let modalDirty = false;
    mBody?.addEventListener('input',  () => { modalDirty = true; });
    mBody?.addEventListener('change', () => { modalDirty = true; });

    function openModal(html, actions) {
        if (mDialog) mDialog.classList.remove('modal-wide');
        mBody.innerHTML = html;
        mActions.innerHTML = '';
        actions.forEach(a => {
            const b = document.createElement('button');
            b.className = 'btn ' + (a.primary ? 'btn-primary' : '');
            b.textContent = a.label;
            b.onclick = a.onClick;
            mActions.appendChild(b);
        });
        modalDirty = false;
        overlay.style.display = 'flex';
    }
    function closeModal() { overlay.style.display = 'none'; modalDirty = false; }
    function requestCloseModal() {
        if (overlay.style.display === 'none') return;
        if (modalDirty && !confirm('You changed something in this dialog. Close without saving?')) return;
        closeModal();
    }
    // Escape closes any open modal; a click on the backdrop does too — both guarded by the dirty check.
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.style.display !== 'none') { e.preventDefault(); requestCloseModal(); }
    });
    overlay.addEventListener('mousedown', (e) => { if (e.target === overlay) requestCloseModal(); });

    document.getElementById('btn-bulkcreate')?.addEventListener('click', () => {
        const n = document.getElementById('cnt-createnew').textContent;
        openModal(
            '<h3>Bulk create items</h3><p>You are about to create <strong>' + n + '</strong> item(s) in SAP and Odoo (including any previously failed lines, which will be retried). This is irreversible. Continue?</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Create ' + n + ' item(s)', primary: true, onClick: runBulkCreate }
            ]);
    });

    async function runBulkCreate() {
        mBody.innerHTML = '<h3>Creating items…</h3><p>This can take up to a minute or two. Please keep this page open.</p><div class="spinner"></div>';
        mActions.innerHTML = '';
        try {
            const r = await api('POST', '/bulk-create');
            let html = '<h3>Bulk create complete</h3><p>Created ' + r.created + ' of ' + r.attempted + '. Failed: ' + r.failed + '.</p>';
            if (r.failures && r.failures.length) {
                html += '<ul class="failure-list">';
                r.failures.forEach(f => { html += '<li><strong>' + (f.articleNumber || f.article_number || '?') + '</strong>: ' + (f.error) + '</li>'; });
                html += '</ul>';
            }
            mBody.innerHTML = html;
            mActions.innerHTML = '';
            const b = document.createElement('button'); b.className = 'btn btn-primary'; b.textContent = 'Close';
            b.onclick = () => location.reload(); mActions.appendChild(b);
        } catch (e) {
            mBody.innerHTML = '<h3>Bulk create failed</h3><p>' + e.message + '</p>';
            const b = document.createElement('button'); b.className = 'btn'; b.textContent = 'Close'; b.onclick = () => location.reload();
            mActions.innerHTML = ''; mActions.appendChild(b);
        }
    }

    document.getElementById('btn-complete')?.addEventListener('click', () => {
        openModal(
            '<h3>Complete review</h3><p>Mark this invoice as reviewed? All lines must be matched, created, or skipped. You won\'t be able to edit lines afterward.</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Mark reviewed', primary: true, onClick: runComplete }
            ]);
    });

    async function runComplete() {
        mActions.innerHTML = '';
        try {
            await api('POST', '/complete-review');
            window.location = '/documents';
        } catch (e) {
            mBody.innerHTML = '<h3>Cannot complete review</h3><p>' + e.message + '</p>';
            const b = document.createElement('button'); b.className = 'btn'; b.textContent = 'Close'; b.onclick = closeModal;
            mActions.innerHTML = ''; mActions.appendChild(b);
        }
    }

    // ---- Purchase Order (vendor PO in SAP B1 from the reviewed invoice) ----
    // HTML/attribute escaping — descriptions and server messages are interpolated into modal markup.
    const escH = s => String(s ?? '').replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
    const escA = s => String(s ?? '').replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    function closeButton(label) {
        mActions.innerHTML = '';
        const b = document.createElement('button'); b.className = 'btn'; b.textContent = label || 'Close'; b.onclick = closeModal;
        mActions.appendChild(b);
    }

    document.getElementById('btn-createpo')?.addEventListener('click', createPurchaseOrder);

    async function createPurchaseOrder() {
        openModal('<h3>Create Purchase Order</h3><p>Building preview…</p><div class="spinner"></div>',
            [{ label: 'Cancel', onClick: closeModal }]);
        let p;
        try { p = await api('GET', '/purchase-order/preview'); }
        catch (e) { mBody.innerHTML = '<h3>Could not build PO preview</h3><p>' + escH(e.message) + '</p>'; closeButton(); return; }

        if (!p.ready) {
            let html = '<h3>Cannot create Purchase Order</h3><p>Resolve the following first:</p><ul class="failure-list">';
            (p.blocking || []).forEach(x => { html += '<li>' + escH(x) + '</li>'; });
            html += '</ul>';
            mBody.innerHTML = html; closeButton(); return;
        }
        renderPoForm(p);
    }

    function poLineTotal(qty, price, disc) {
        const t = (Number(qty) || 0) * (Number(price) || 0) * (1 - (Number(disc) || 0) / 100);
        return (isFinite(t) ? t : 0).toFixed(2);
    }

    function poRowHtml(line) {
        const q = line.quantity ?? 0, u = line.unit_price ?? 0, d = line.discount_pct ?? 0;
        return '<tr>' +
            '<td><input class="cell-input po-item" value="' + escA(line.item_code) + '"></td>' +
            '<td class="po-desc">' + escH(line.description) + '</td>' +
            '<td><input class="cell-input num po-qty" type="number" step="any" min="0" value="' + escA(q) + '"></td>' +
            '<td><input class="cell-input num po-price" type="number" step="any" min="0" value="' + escA(u) + '"></td>' +
            '<td><input class="cell-input num po-disc" type="number" step="any" min="0" max="100" value="' + escA(d) + '"></td>' +
            '<td class="num po-total">' + poLineTotal(q, u, d) + '</td>' +
            '<td><button type="button" class="btn btn-sm po-del" title="Remove line">✕</button></td>' +
            '</tr>';
    }

    function renderPoForm(p) {
        let html = '<h3>Create Purchase Order</h3>' +
            '<table class="po-meta"><tbody>' +
            '<tr><th>Vendor</th><td>' + escH(p.card_code) + ' — ' + escH(p.card_name) + '</td></tr>' +
            '<tr><th>Currency</th><td>' + escH(p.currency) + '</td></tr>' +
            '<tr><th>Vendor ref (invoice no.)</th><td>' + escH(p.num_at_card) + '</td></tr>' +
            '<tr><th>Comments</th><td>' + escH(p.comments) + '</td></tr>' +
            '<tr><th>Warehouse</th><td>' + escH(p.warehouse) + '</td></tr>' +
            '</tbody></table>' +
            '<table class="po-lines"><thead><tr>' +
            '<th>Item code</th><th>Description</th><th class="num">Qty</th><th class="num">Unit price</th>' +
            '<th class="num">Disc %</th><th class="num">Line total</th><th></th>' +
            '</tr></thead><tbody id="po-rows">' + (p.lines || []).map(poRowHtml).join('') + '</tbody></table>' +
            '<button type="button" class="btn btn-sm" id="po-add">+ Add line</button>';
        openModal(html, [
            { label: 'Cancel', onClick: closeModal },
            { label: 'Post PO', primary: true, onClick: postPurchaseOrder }
        ]);
        if (mDialog) mDialog.classList.add('modal-wide');

        document.getElementById('po-add').onclick = () => {
            const tr = document.createElement('tr');
            tr.innerHTML = poRowHtml({ item_code: '', description: '', quantity: 0, unit_price: 0, discount_pct: 0 });
            document.getElementById('po-rows').appendChild(tr);
        };
        document.getElementById('po-rows').addEventListener('click', e => {
            if (e.target.classList.contains('po-del')) e.target.closest('tr').remove();
        });
        // Live line-total as qty / price / discount change.
        document.getElementById('po-rows').addEventListener('input', e => {
            const tr = e.target.closest('tr'); if (!tr) return;
            const cell = tr.querySelector('.po-total');
            if (cell) cell.textContent = poLineTotal(
                tr.querySelector('.po-qty')?.value,
                tr.querySelector('.po-price')?.value,
                tr.querySelector('.po-disc')?.value);
        });
    }

    async function postPurchaseOrder() {
        const lines = Array.from(document.querySelectorAll('#po-rows tr')).map(tr => ({
            item_code: (tr.querySelector('.po-item')?.value || '').trim(),
            quantity: Number(tr.querySelector('.po-qty')?.value || 0),
            unit_price: Number(tr.querySelector('.po-price')?.value || 0),
            discount_pct: Number(tr.querySelector('.po-disc')?.value || 0)
        })).filter(l => l.item_code && l.quantity > 0);
        if (!lines.length) { alert('Add at least one line with an item code and quantity > 0.'); return; }

        mBody.innerHTML = '<h3>Posting Purchase Order…</h3><p>Contacting SAP B1. Please keep this page open.</p><div class="spinner"></div>';
        mActions.innerHTML = '';
        try {
            const r = await api('POST', '/purchase-order', { lines });
            mBody.innerHTML = '<h3>Purchase Order created</h3><p>DocNum <strong>' + escH(r.doc_num) +
                '</strong> (entry ' + escH(r.doc_entry) + ') for invoice ' + escH(r.num_at_card) + '.</p>';
            closeButton();
        } catch (e) {
            // 409 (already exists) and other failures both surface their server message here.
            mBody.innerHTML = '<h3>Could not create Purchase Order</h3><p>' + escH(e.message) + '</p>';
            closeButton();
        }
    }

    refreshSummary();
})();
</script>

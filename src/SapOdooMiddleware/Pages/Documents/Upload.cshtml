@page "/documents/upload"
@model SapOdooMiddleware.Pages.Documents.UploadModel

<h2>Upload invoice</h2>

@if (Model.Error is not null)
{
    <div class="error">@Model.Error</div>
}

<div class="card" style="max-width:560px;">
    <form method="post" enctype="multipart/form-data">
        <p>Select a Liqui Moly invoice PDF to upload. Extraction starts automatically.</p>
        <p><input type="file" name="Pdf" accept=".pdf" required /></p>
        <p>
            <button class="btn" type="submit">Upload &amp; extract</button>
            <a href="/documents" style="margin-left:12px;">Cancel</a>
        </p>
    </form>
</div>

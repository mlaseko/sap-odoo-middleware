@page "/admin"
@model SapOdooMiddleware.Pages.Admin.IndexModel

<div class="page-head">
    <div>
        <h2>Admin &amp; operations</h2>
        <div class="sub">Connectivity checks, taxonomy reload, and the webhook retry queue</div>
    </div>
</div>

<div class="admin-grid">

    <div class="card">
        <p class="card-title">Connections</p>
        <div class="kv"><span class="k"><span id="sap-dot" class="status-dot"></span>SAP B1 (DI API)</span><span class="v" id="sap-state">—</span></div>
        <div class="kv"><span class="k"><span id="odoo-dot" class="status-dot"></span>Odoo (JSON-RPC)</span><span class="v" id="odoo-state">—</span></div>
        <div class="admin-result" id="conn-detail"></div>
        <div class="card-actions">
            <button class="btn btn-primary" id="btn-ping">Ping both</button>
        </div>
    </div>

    <div class="card">
        <p class="card-title">Odoo category taxonomy</p>
        <div class="kv"><span class="k">Status</span><span class="v" id="tax-loaded">—</span></div>
        <div class="kv"><span class="k">Categories</span><span class="v" id="tax-count">—</span></div>
        <div class="kv"><span class="k">Loaded at</span><span class="v" id="tax-at">—</span></div>
        <div class="admin-result" id="tax-detail">The validator auto-reloads on file change; use this after pushing a new bundle from DGX.</div>
        <div class="card-actions">
            <button class="btn" id="btn-tax-refresh">Refresh status</button>
            <button class="btn btn-primary" id="btn-tax-reload">Reload taxonomy</button>
        </div>
    </div>

    <div class="card">
        <p class="card-title">Webhook queue</p>
        <div id="wq-summary"><div class="kv"><span class="k">Loading…</span><span class="v"></span></div></div>
        <div class="admin-result" id="wq-detail"></div>
        <div class="card-actions">
            <button class="btn" id="btn-wq-refresh">Refresh</button>
            <button class="btn btn-danger" id="btn-wq-retry">Retry all failed</button>
        </div>
    </div>

</div>

<script>
(function () {
    const API_KEY = document.querySelector('meta[name="api-key"]')?.content || '';
    async function call(method, path) {
        const opts = { method, headers: {} };
        if (API_KEY) opts.headers['X-Api-Key'] = API_KEY;
        const r = await fetch(path, opts);
        const text = await r.text();
        const json = text ? JSON.parse(text) : null;
        if (!r.ok) throw new Error((json && (json.error || (json.errors && json.errors.join('; ')))) || ('HTTP ' + r.status));
        return json;
    }
    // ApiResponse<T> wraps as { success, data }; the admin taxonomy endpoints return raw objects.
    const unwrap = j => (j && typeof j === 'object' && 'data' in j && 'success' in j) ? j.data : j;
    const esc = s => String(s ?? '').replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
    const fmtTime = t => { if (!t) return '—'; const d = new Date(t); return isNaN(d) ? esc(t) : d.toLocaleString(); };
    function setDot(id, ok) { const el = document.getElementById(id); el.className = 'status-dot ' + (ok ? 'ok' : 'bad'); }

    // ---- connections ----
    async function pingSap() {
        document.getElementById('sap-dot').className = 'status-dot wait';
        try {
            const d = unwrap(await call('GET', '/api/sapb1/ping'));
            setDot('sap-dot', !!d.connected);
            document.getElementById('sap-state').textContent = d.connected ? 'Connected' : 'Disconnected';
            return d.connected
                ? 'SAP: ' + esc(d.company_name || d.company_db || '') + (d.version ? ' · v' + esc(d.version) : '') + ' @ ' + esc(d.server || '')
                : 'SAP: not connected';
        } catch (e) { setDot('sap-dot', false); document.getElementById('sap-state').textContent = 'Error'; return 'SAP: ' + esc(e.message); }
    }
    async function pingOdoo() {
        document.getElementById('odoo-dot').className = 'status-dot wait';
        try {
            const d = unwrap(await call('GET', '/api/odoo/ping'));
            setDot('odoo-dot', !!d.connected);
            document.getElementById('odoo-state').textContent = d.connected ? 'Connected' : 'Disconnected';
            return d.connected
                ? 'Odoo: ' + esc(d.database || '') + (d.server_version ? ' · v' + esc(d.server_version) : '') + ' (' + esc(d.user_name || ('uid ' + d.uid)) + ')'
                : 'Odoo: not connected';
        } catch (e) { setDot('odoo-dot', false); document.getElementById('odoo-state').textContent = 'Error'; return 'Odoo: ' + esc(e.message); }
    }
    async function pingBoth() {
        const btn = document.getElementById('btn-ping'); btn.disabled = true;
        document.getElementById('conn-detail').textContent = 'Pinging…';
        const [a, b] = await Promise.all([pingSap(), pingOdoo()]);
        document.getElementById('conn-detail').innerHTML = esc(a) + '<br>' + esc(b);
        btn.disabled = false;
    }

    // ---- taxonomy ----
    function renderTax(d) {
        document.getElementById('tax-loaded').innerHTML = d.loaded
            ? '<span class="pill pill-green">loaded</span>' : '<span class="pill pill-grey">fail-open</span>';
        document.getElementById('tax-count').textContent = d.count ?? 0;
        document.getElementById('tax-at').textContent = fmtTime(d.loaded_at);
    }
    async function taxRefresh() {
        try { renderTax(unwrap(await call('GET', '/api/admin/taxonomy'))); }
        catch (e) { document.getElementById('tax-detail').textContent = e.message; }
    }
    async function taxReload() {
        const btn = document.getElementById('btn-tax-reload'); btn.disabled = true;
        document.getElementById('tax-detail').textContent = 'Reloading…';
        try {
            const d = unwrap(await call('POST', '/api/admin/reload-taxonomy'));
            renderTax(d);
            document.getElementById('tax-detail').textContent = 'Reloaded ' + (d.count ?? 0) + ' categories from ' + esc(d.path || 'disk') + '.';
        } catch (e) { document.getElementById('tax-detail').textContent = 'Reload failed: ' + e.message; }
        btn.disabled = false;
    }

    // ---- webhook queue ----
    function renderWq(summary) {
        const order = ['failed', 'pending', 'processing', 'completed', 'dead'];
        const keys = Object.keys(summary || {}).sort((a, b) => (order.indexOf(a) + 1 || 99) - (order.indexOf(b) + 1 || 99));
        const pill = k => k === 'failed' || k === 'dead' ? 'pill-red' : k === 'pending' || k === 'processing' ? 'pill-yellow' : 'pill-green';
        const el = document.getElementById('wq-summary');
        if (!keys.length) { el.innerHTML = '<div class="kv"><span class="k">Queue empty</span><span class="v">0</span></div>'; return; }
        el.innerHTML = keys.map(k =>
            '<div class="kv"><span class="k"><span class="pill ' + pill(k) + '">' + esc(k) + '</span></span><span class="v">' + (summary[k] | 0) + '</span></div>').join('');
    }
    async function wqRefresh() {
        try { renderWq(unwrap(await call('GET', '/api/webhook-queue/summary'))); }
        catch (e) { document.getElementById('wq-detail').textContent = e.message; }
    }
    async function wqRetry() {
        const btn = document.getElementById('btn-wq-retry'); btn.disabled = true;
        document.getElementById('wq-detail').textContent = 'Re-queuing failed entries…';
        try {
            const d = unwrap(await call('POST', '/api/webhook-queue/retry-all'));
            document.getElementById('wq-detail').textContent = 'Re-queued ' + (d.retried_count ?? 0) + ' failed entr' + ((d.retried_count === 1) ? 'y' : 'ies') + '.';
            await wqRefresh();
        } catch (e) { document.getElementById('wq-detail').textContent = 'Retry failed: ' + e.message; }
        btn.disabled = false;
    }

    document.getElementById('btn-ping').addEventListener('click', pingBoth);
    document.getElementById('btn-tax-refresh').addEventListener('click', taxRefresh);
    document.getElementById('btn-tax-reload').addEventListener('click', taxReload);
    document.getElementById('btn-wq-refresh').addEventListener('click', wqRefresh);
    document.getElementById('btn-wq-retry').addEventListener('click', wqRetry);

    // initial load
    pingBoth();
    taxRefresh();
    wqRefresh();
})();
</script>

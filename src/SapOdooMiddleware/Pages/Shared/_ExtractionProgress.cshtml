@model SapOdooMiddleware.Pages.ExtractionProgressVm
@*
    Shared live extraction-progress card + poller. Anchors page-elapsed to the server clock
    (skew-free) and interpolates locally between polls so the bar moves smoothly within a page.
    Reusable across tenants via the StatusUrl. (Lubes Detail still inlines its own copy today.)
*@
<div id="progress-card" class="progress-card" style="display:none">
    <div class="progress-header">
        <span class="progress-label" id="pp-label">Extracting…</span>
        <span class="progress-page-text" id="pp-pagetext">Preparing…</span>
    </div>
    <div class="progress-bar-track">
        <div class="progress-bar-fill" id="pp-fill" style="width: 0%"></div>
    </div>
    <div class="progress-meta">
        <span id="pp-percent"></span>
        <span id="pp-elapsed"></span>
        <span id="pp-eta"></span>
    </div>
</div>

<style>
    /* Indeterminate "warming up" sweep, shown while no page has completed yet (PagesProcessed == 0). */
    .progress-bar-fill.indeterminate {
        width: 35% !important;
        background-image: linear-gradient(90deg, transparent, rgba(255,255,255,.55), transparent);
        animation: pp-indeterminate 1.2s ease-in-out infinite;
    }
    @@keyframes pp-indeterminate {
        0%   { transform: translateX(-120%); }
        100% { transform: translateX(320%); }
    }
</style>

<script>
(function () {
    const initialStatus = @Json.Serialize(Model.Status);
    const STATUS_URL = @Json.Serialize(Model.StatusUrl);
    const ACTIVE_STATUSES = ['uploaded', 'extracting'];

    if (!ACTIVE_STATUSES.includes(initialStatus)) return;

    const card = document.getElementById('progress-card');
    const fill = document.getElementById('pp-fill');
    const label = document.getElementById('pp-label');
    const pageText = document.getElementById('pp-pagetext');
    const percent = document.getElementById('pp-percent');
    const elapsed = document.getElementById('pp-elapsed');
    const eta = document.getElementById('pp-eta');

    card.style.display = 'block';

    const DEFAULT_PAGE_SEC = 60;
    const INTRA_PAGE_CAP = 0.92;

    let pollTimer = null;
    let tickTimer = null;
    let snap = null;
    let maxPct = 0;   // monotonic guard: the bar never moves backwards within a session

    function fmtSec(s) {
        if (s == null || !isFinite(s) || s < 0) return '';
        s = Math.round(s);
        if (s < 60) return s + 's';
        const m = Math.floor(s / 60);
        return m + 'm ' + (s - m * 60) + 's';
    }

    function pageElapsedNow() {
        if (!snap || snap.pageElapsedAtSnapSec == null) return null;
        return snap.pageElapsedAtSnapSec + (Date.now() - snap.localAnchorMs) / 1000;
    }

    function render() {
        if (!snap) return;
        const { pageCount, pagesProcessed, expectedSec, status } = snap;
        const elapsedSec = pageElapsedNow();

        // Until the first page actually completes, per-page progress is unreliable (a cold DGX may
        // retry page 1, cycling CurrentPageStartedAt) — so show an honest indeterminate state with
        // a live activity message instead of a number that flickers 0 → 2% → 0.
        if (pagesProcessed === 0) {
            fill.classList.add('indeterminate');
            percent.textContent = '';
            eta.textContent = '';
            if (status === 'uploaded') {
                label.textContent = 'Queued…';
                pageText.textContent = 'Waiting in the extraction queue';
                elapsed.textContent = '';
            } else if (elapsedSec != null) {
                label.textContent = 'Extracting…';
                pageText.textContent = pageCount > 0 ? ('Page 1 of ' + pageCount) : 'Page 1';
                elapsed.textContent = 'page time: ' + fmtSec(elapsedSec);
            } else {
                label.textContent = 'Starting…';
                pageText.textContent = 'Waiting for the extractor to start';
                elapsed.textContent = '';
            }
            return;
        }

        fill.classList.remove('indeterminate');

        let frac = 0;
        if (elapsedSec != null && expectedSec > 0) {
            frac = Math.min(elapsedSec / expectedSec, INTRA_PAGE_CAP);
        }
        const done = pageCount > 0 ? (pagesProcessed + frac) / pageCount : 0;
        let pct = Math.max(0, Math.min(100, done * 100));
        pct = Math.max(pct, maxPct);   // never go backwards
        maxPct = pct;

        label.textContent = 'Extracting…';
        fill.style.width = pct.toFixed(1) + '%';
        percent.textContent = Math.floor(pct) + '%';
        pageText.textContent = 'Page ' + pagesProcessed + ' of ' + pageCount;

        elapsed.textContent = elapsedSec != null ? 'page time: ' + fmtSec(elapsedSec) : '';

        const pagesAfterCurrent = Math.max(0, pageCount - pagesProcessed - (elapsedSec != null ? 1 : 0));
        let remaining = pagesAfterCurrent * expectedSec;
        if (elapsedSec != null) remaining += Math.max(expectedSec - elapsedSec, 0);
        eta.textContent = (pageCount > 0 && remaining > 0) ? 'eta: ' + fmtSec(remaining) : '';
    }

    async function poll() {
        try {
            const r = await fetch(STATUS_URL, { cache: 'no-store' });
            if (!r.ok) return;
            const s = await r.json();   // snake_case payload (API uses SnakeCaseLower)

            const pageCount = s.page_count || 0;
            const pagesProcessed = s.pages_processed || 0;
            const expectedSec = (s.last_page_duration_sec != null && s.last_page_duration_sec > 0)
                ? Number(s.last_page_duration_sec) : DEFAULT_PAGE_SEC;

            let pageElapsedAtSnapSec = null;
            if (s.current_page_started_at_utc && s.server_now_utc) {
                const started = Date.parse(s.current_page_started_at_utc);
                const serverNow = Date.parse(s.server_now_utc);
                if (isFinite(started) && isFinite(serverNow)) {
                    pageElapsedAtSnapSec = Math.max(0, (serverNow - started) / 1000);
                }
            }

            snap = { status: s.status, pageCount, pagesProcessed, expectedSec, pageElapsedAtSnapSec, localAnchorMs: Date.now() };
            render();

            if (!ACTIVE_STATUSES.includes(s.status)) {
                clearInterval(pollTimer);
                clearInterval(tickTimer);
                fill.classList.remove('indeterminate');
                fill.style.width = '100%';
                percent.textContent = '100%';
                setTimeout(() => location.reload(), 250);
            }
        } catch (e) {
            // Network blip — keep polling.
        }
    }

    pollTimer = setInterval(poll, 1500);
    tickTimer = setInterval(render, 250);
    poll();
})();
</script>

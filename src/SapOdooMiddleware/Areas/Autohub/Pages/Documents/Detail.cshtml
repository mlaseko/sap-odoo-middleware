@page "/autohub/documents/{id:guid}"
@model SapOdooMiddleware.Areas.Autohub.Pages.Documents.DetailModel
@{
    var badge = Model.ValidationBadge();
    var sym = Model.Sym();
}

<div class="page-head">
    <div>
        <h2>@(Model.Doc.InvoiceNumber ?? Model.Doc.OriginalFilename)</h2>
        <div class="sub">@Model.Doc.SupplierName</div>
    </div>
    <div style="display:flex; gap:12px; align-items:center;">
        <button id="btn-delete-doc" class="btn btn-sm btn-danger" type="button" data-doc-id="@Model.Doc.Id">Delete invoice</button>
        <a class="btn btn-sm" href="/autohub/documents">← Back to list</a>
    </div>
</div>

<style>
    .hint { font-weight: normal; color: var(--muted); font-size: 13px; }
    #lines-table thead th { position: sticky; top: 58px; background: var(--surface-2); z-index: 2; }
    #lines-table th.col-desc, #lines-table td.col-desc { min-width: 200px; }
    #lines-table th.col-oems, #lines-table td.col-oems { min-width: 170px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #lines-table th.col-art, #lines-table td.col-art { white-space: nowrap; }
    #lines-table td .unit { color: var(--muted-2); font-size: 12px; }
    #lines-table tr.line-row { cursor: pointer; }
    #lines-table tr.line-row:hover { background: rgba(255,255,255,.04); }
    #lines-table tr.line-row.expanded { background: var(--accent-soft); }
    .line-detail { padding: 12px 14px; background: var(--surface-2); border-left: 3px solid var(--accent); border-radius: 0 0 8px 8px; }
    .line-detail .ld-meta { display: flex; gap: 18px; flex-wrap: wrap; margin-bottom: 8px; font-size: 13px; color: var(--text); }
    .line-detail .ld-meta label, .line-detail .ld-edit label { color: var(--muted); font-weight: 600; margin-right: 4px; font-size: 12px; }
    .line-detail .ld-edit { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; margin-bottom: 10px; }
    .line-detail .ld-edit input { padding: 5px 8px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-elev); color: var(--text); }
    .line-detail .ld-edit input.ld-qty, .line-detail .ld-edit input.ld-price { width: 90px; }
    .line-detail .ld-desc-wrap { flex: 1 1 260px; }
    .line-detail .ld-desc-wrap input { width: 100%; }
    .line-detail .ld-enrichment { font-size: 13px; }
    .line-detail .ld-enrichment h3 { font-size: 14px; margin: 4px 0; color: var(--text-strong); }
    .line-detail .kv th { text-align: left; color: var(--muted); padding-right: 10px; font-weight: 600; vertical-align: top; }
    .ld-saved { color: var(--success); }
    .ld-borrowed { color: var(--warning); }
    .ld-error { color: var(--danger); }
    .ld-img { max-height: 120px; border: 1px solid var(--border); border-radius: 6px; margin-top: 8px; }
    /* Donor-swap modal: wider window + card-per-candidate so every field (incl. the full OEM list) shows. */
    .modal.modal-wide { max-width: min(980px, 96vw); width: min(980px, 96vw); }
    .dc-title { margin: 0 0 4px; }
    .donor-head-note { color: var(--muted); font-size: 13px; margin: 0 0 14px; line-height: 1.5; }
    .donor-list { max-height: 64vh; overflow-y: auto; padding-right: 4px; display:flex; flex-direction:column; gap:10px; }
    .dc { display:flex; gap:14px; align-items:flex-start; padding:12px 14px; border:1px solid var(--border); border-radius:10px; cursor:pointer; transition: border-color .12s, background .12s; }
    .dc:hover { background: rgba(255,255,255,.03); }
    .dc:has(> input:checked) { border-color: var(--primary, #7c6cff); background: rgba(124,108,255,.09); box-shadow: 0 0 0 1px var(--primary, #7c6cff) inset; }
    .dc > input { margin-top:5px; flex:0 0 auto; accent-color: var(--primary, #7c6cff); }
    .dc-wrong { opacity:.82; }
    .donor-img { flex:0 0 auto; width:60px; height:60px; display:flex; align-items:center; justify-content:center; background:#fff; border-radius:8px; overflow:hidden; border:1px solid var(--border); }
    .donor-img img { width:60px; height:60px; object-fit:contain; }
    .donor-img.noimg::after { content:'no image'; font-size:9px; color:#999; }
    .dc-main { flex:1 1 auto; min-width:0; }
    .dc-top { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .dc-art { font-weight:700; font-size:14px; }
    .dc-cur { font-size:11px; color: var(--muted); font-style:italic; }
    .dc-chip { display:inline-block; padding:1px 7px; border-radius:5px; font-size:11px; }
    .dc-chip-code { background: rgba(255,255,255,.08); color: var(--muted); font-family: ui-monospace, monospace; }
    .dc-verdict { font-size:10px; font-weight:700; letter-spacing:.4px; padding:2px 9px; border-radius:20px; }
    .dc-verdict.v-match { background: rgba(52,199,89,.16); color:#37c85a; }
    .dc-verdict.v-unc   { background: rgba(255,204,0,.16); color:#e6b800; }
    .dc-verdict.v-diff  { background: rgba(255,69,58,.16); color:#ff6961; }
    .dc-hand { font-size:13px; }
    .dc-name { margin-top:6px; font-size:13px; }
    .dc-sup { color: var(--muted); }
    .dc-meta { margin-top:3px; font-size:11px; color: var(--muted); }
    .dc-oems { margin-top:9px; display:flex; gap:8px; align-items:baseline; }
    .dc-oems-lbl { flex:0 0 auto; font-size:11px; font-weight:700; color: var(--text-strong); text-transform:uppercase; letter-spacing:.4px; }
    .dc-oems-wrap { display:flex; flex-wrap:wrap; gap:4px; max-height:108px; overflow:auto; }
    .oem-chip { font-family: ui-monospace, monospace; font-size:11px; padding:2px 7px; border-radius:5px; background: rgba(120,140,255,.14); color:#aab6ff; white-space:nowrap; }
    .oem-more { font-size:11px; padding:2px 4px; color: var(--muted); align-self:center; }
    .dc-xref { margin-top:7px; font-size:11px; color: var(--muted); opacity:.85; }
    .dc-dim { color: var(--muted); }
    .enrich-indicator { display:inline-flex; align-items:center; gap:8px; margin-top:8px; font-size:0.85rem; color: var(--warning); }
    .enrich-dot { width:9px; height:9px; border-radius:50%; background: var(--warning); animation: enrich-pulse 1.1s ease-in-out infinite; }
    @@keyframes enrich-pulse { 0%,100% { opacity:.35; transform:scale(.85); } 50% { opacity:1; transform:scale(1.1); } }
</style>

@* Header card *@
<div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            Status: <strong>@Model.Doc.Status</strong>
            &nbsp;|&nbsp; Validation: <span class="badge @badge.Css">@badge.Text</span>
        </div>
        <div>@Model.Doc.PageCount page(s)</div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Doc.ErrorMessage))
    {
        <div class="note-error">@Model.Doc.ErrorMessage</div>
    }
</div>

@* Live progress (shared partial; targets the Autohub status endpoint) *@
@{
    var progressVm = new ExtractionProgressVm(
        Model.Doc.Id, Model.Doc.Status, $"/api/autohub/documents/{Model.Doc.Id}/status");
}
<partial name="/Pages/Shared/_ExtractionProgress.cshtml" model="progressVm" />

@* Invoice metadata *@
<div class="card">
    <table>
        <tbody>
            <tr><th>Supplier</th><td>@Model.Doc.SupplierName</td>
                <th>Invoice number</th><td>@Model.Doc.InvoiceNumber</td></tr>
            <tr><th>Invoice date</th><td>@(Model.Doc.InvoiceDate?.ToString("yyyy-MM-dd"))</td>
                <th>Currency</th><td>@Model.Doc.Currency</td></tr>
            <tr><th>Total amount</th><td class="num">@(Model.Doc.TotalAmount is { } t ? sym + t.ToString("N2") : "")</td>
                <th></th><td></td></tr>
        </tbody>
    </table>
</div>

@if (Model.Doc.Status == "extracted" && Model.Lines.Count == 0)
{
    <div class="note-warn">
        Extraction succeeded but no line items were found. Check the file or operator review may be required.
    </div>
}

@if (Model.ShowReview)
{
    <div id="review-banner" class="review-banner" data-doc-id="@Model.Doc.Id" data-editable="@Model.IsEditable.ToString().ToLowerInvariant()">
        <div class="review-counts" id="review-counts">
            📋 Review:
            <span class="rc">@Model.Count("matched") matched</span> ·
            <span class="rc">@Model.Count("created") created</span> ·
            <span class="rc">@Model.Count("create_new") to create</span> ·
            <span class="rc">@Model.Count("skip") skipped</span> ·
            <span class="rc">@Model.Count("needs_manual") needs manual</span> ·
            <span class="rc">@Model.Count("needs_confirmation") confirm</span> ·
            <span class="rc">@Model.Count("pending") pending</span> ·
            <span class="rc">@Model.Count("create_failed") failed</span>
        </div>
        <div class="enrich-indicator" id="enrich-indicator" style="display:none;">
            <span class="enrich-dot"></span><span id="enrich-text">Enrichment running…</span>
        </div>
        @if (Model.IsReviewed)
        {
            <div class="review-done">✓ Reviewed</div>
        }
        else
        {
            <div class="review-actions">
                <button id="btn-automatch" class="btn btn-sm" type="button">Auto-match again</button>
                <button id="btn-markpending" class="btn btn-sm" type="button">Mark all pending as Create New</button>
                <button id="btn-skip-pending" class="btn btn-sm" type="button">Skip All Pending (<span id="cnt-skip-pending">@(Model.Count("pending") + Model.Count("needs_manual"))</span>)</button>
                <button id="btn-reopen-skipped" class="btn btn-sm" type="button">Reopen Skipped (<span id="cnt-reopen-skipped">@Model.Count("skip")</span>)</button>
                <button id="btn-bulkcreate" class="btn btn-sm" type="button">Bulk Create (<span id="cnt-createnew">@(Model.Count("create_new") + Model.Count("create_failed"))</span>)</button>
                <button id="btn-confirm-create" class="btn btn-sm" type="button">Confirm all &amp; Create</button>
                <button id="btn-complete" class="btn btn-sm btn-primary" type="button">Complete Review</button>
            </div>
        }
    </div>
}

<h3>Line items (@Model.Lines.Count) <span class="hint">— click a row for details / edit</span></h3>
@{ var colCount = Model.IsEditable ? 10 : 9; }
<table id="lines-table">
    <thead>
        <tr>
            <th class="num">#</th>
            <th class="col-art">Supplier Art.</th>
            <th class="col-oems">OEMs</th>
            <th class="col-desc">Description</th>
            <th>Brand</th>
            <th class="num">Qty</th>
            <th class="num">Unit Price</th>
            <th class="num">Line Total</th>
            <th>Status</th>
            @if (Model.IsEditable) { <th>Actions</th> }
        </tr>
    </thead>
    <tbody>
    @foreach (var l in Model.Lines)
    {
        var oems = string.Join(", ", l.OemNumbers);
        var pill = SapOdooMiddleware.Areas.Autohub.Pages.Documents.DetailModel.LinePill(l.ReviewStatus);
        <tr class="line-row @(l.IsPromotional ? "promo" : null)" data-line-id="@l.Id"
            data-suggested-code="@l.SuggestedDonorItemCode" data-suggested-supplier="@l.SuggestedDonorSupplier"
            data-source="@l.EnrichmentSource">
            <td class="num">@l.LineNumber</td>
            <td class="col-art">@l.SupplierArticleNumber</td>
            <td class="col-oems" title="@oems">@oems</td>
            <td class="col-desc">@l.Description</td>
            <td>@l.Brand</td>
            <td class="num">@(l.Quantity?.ToString("0.###")) <span class="unit">@l.Unit</span></td>
            <td class="num">@(l.UnitPriceForeign is { } up ? sym + up.ToString("N2") : "")</td>
            <td class="num">@(l.LineTotalForeign is { } lt ? sym + lt.ToString("N2") : "")</td>
            <td class="status-cell">
                <span class="pill @pill.Css">@pill.Text</span>
                @{ var sb = SapOdooMiddleware.Areas.Autohub.Pages.Documents.DetailModel.SourceBadge(l.MatchStrategy); }
                @if (sb.Label.Length > 0)
                {
                    <span class="pill @sb.Css" title="@l.MatchStrategy" style="margin-left:4px;">@sb.Label</span>
                }
                @if (l.NeedsReview)
                {
                    <span class="pill pill-orange" style="margin-left:4px;"
                          title="Borrowed part type unverified (@l.SelectedComponentVerdict) — review/choose the donor">⚠ review</span>
                }
            </td>
            @if (Model.IsEditable)
            {
                <td class="actions-cell" data-noexpand="1">
                    <details class="actions-menu">
                        <summary>⋮</summary>
                        <div class="menu">
                            <button type="button" data-action="automatch">Auto-match (retry)</button>
                            @if (l.ReviewStatus == "needs_confirmation")
                            {
                                <button type="button" data-action="confirm">Confirm match…</button>
                            }
                            <button type="button" data-action="match">Manual match…</button>
                            <button type="button" data-action="create_new">Create New (SAP)</button>
                            @if (l.HasDonorCandidates && l.ReviewStatus != "created")
                            {
                                <button type="button" data-action="swap_donor">Choose donor…</button>
                            }
                            <button type="button" data-action="reenrich">Re-enrich…</button>
                            @if (l.ReviewStatus != "needs_manual")
                            {
                                <button type="button" data-action="needs_manual">Mark needs manual</button>
                            }
                            <button type="button" data-action="skip">Skip</button>
                            @if (l.ReviewStatus == "skip")
                            {
                                <button type="button" data-action="reopen">Reopen (needs manual)</button>
                            }
                        </div>
                    </details>
                </td>
            }
        </tr>
        <tr class="detail-row" data-line-id="@l.Id" style="display:none">
            <td colspan="@colCount">
                <div class="line-detail">
                    <div class="ld-meta">
                        <span><label>Page</label> @l.PageNumber</span>
                        <span><label>Unit</label> @l.Unit</span>
                        <span><label>Disc %</label> @(l.DiscountPct?.ToString("0.##"))</span>
                        <span class="ld-oems"><label>OEMs</label> @(oems.Length == 0 ? "—" : oems)</span>
                    </div>
                    @if (Model.IsEditable)
                    {
                        <div class="ld-edit">
                            <label>Qty <input type="number" step="any" min="0" class="ld-qty" value="@(l.Quantity?.ToString("0.###"))"></label>
                            <label>Unit price <input type="number" step="any" min="0" class="ld-price" value="@(l.UnitPriceForeign?.ToString("0.####"))"></label>
                            <label class="ld-desc-wrap">Description <input type="text" class="ld-desc" value="@l.Description"></label>
                            <button type="button" class="btn btn-sm ld-save">Save changes</button>
                            <span class="ld-saved" style="display:none;">✓ saved</span>
                        </div>
                    }
                    <div class="ld-enrichment" data-loaded="false"><em>Loading enrichment…</em></div>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (Model.ShowReview && !Model.IsReviewed)
{
    <div id="modal-overlay" class="modal-overlay" style="display:none">
        <div class="modal">
            <div id="modal-body"></div>
            <div id="modal-actions" class="modal-actions"></div>
        </div>
    </div>
}

<script>
// ---- Autohub Phase B review interactions (only active for editable/extracted documents) ----
(function () {
    const banner = document.getElementById('review-banner');
    if (!banner || banner.dataset.editable !== 'true') return;

    const docId = banner.dataset.docId;
    const base = '/api/autohub/documents/' + docId;

    const PILL = {
        matched: ['pill-green', 'matched'], create_new: ['pill-blue', 'create new'],
        skip: ['pill-grey', 'skip'], pending: ['pill-yellow', 'pending'],
        created: ['pill-green', 'created'], create_failed: ['pill-red', 'create failed'],
        needs_manual: ['pill-orange', 'needs manual'], needs_confirmation: ['pill-purple', 'confirm match']
    };

    const API_KEY = document.querySelector('meta[name="api-key"]')?.content || '';

    async function api(method, path, body) {
        const opts = { method, headers: {} };
        if (API_KEY) opts.headers['X-Api-Key'] = API_KEY;
        if (body !== undefined) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
        const r = await fetch(base + path, opts);
        const text = await r.text();
        const json = text ? JSON.parse(text) : null;
        if (!r.ok) throw new Error((json && json.error) || ('HTTP ' + r.status));
        return json;
    }

    const esc = s => (s == null ? '' : String(s).replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c])));
    const SYM = "@sym";
    const fmtMoney = v => SYM + Number(v).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function setRowPill(row, status) {
        const [cls, label] = PILL[status] || ['pill-grey', status];
        row.querySelector('.status-cell').innerHTML = '<span class="pill ' + cls + '">' + label + '</span>';
    }

    // ---- review summary banner ----
    async function refreshSummary() {
        let s;
        try { s = await api('GET', '/review-summary'); } catch (e) { return; }
        const b = s.by_status || {};
        document.getElementById('review-counts').innerHTML =
            '📋 Review: <span class="rc">' + (b.matched || 0) + ' matched</span> · ' +
            '<span class="rc">' + (b.created || 0) + ' created</span> · ' +
            '<span class="rc">' + (b.create_new || 0) + ' to create</span> · ' +
            '<span class="rc">' + (b.skip || 0) + ' skipped</span> · ' +
            '<span class="rc">' + (b.needs_manual || 0) + ' needs manual</span> · ' +
            '<span class="rc">' + (b.needs_confirmation || 0) + ' confirm</span> · ' +
            '<span class="rc">' + (b.pending || 0) + ' pending</span> · ' +
            '<span class="rc">' + (b.create_failed || 0) + ' failed</span>';
        // Background-enrichment indicator: visible while DGX is still enriching this document's lines.
        const awaiting = s.awaiting_enrichment || 0;
        const ei = document.getElementById('enrich-indicator');
        const et = document.getElementById('enrich-text');
        if (ei) {
            if (awaiting > 0) {
                ei.style.display = '';
                if (et) et.textContent = 'Enrichment running… ' + awaiting + ' line' + (awaiting === 1 ? '' : 's') + ' to go';
            } else {
                ei.style.display = 'none';
            }
        }
        const skipN = (b.pending || 0) + (b.needs_manual || 0);
        const createN = (b.create_new || 0) + (b.create_failed || 0);   // failed lines are retried by Bulk Create
        const cnt = document.getElementById('cnt-createnew'); if (cnt) cnt.textContent = createN;
        const mp = document.getElementById('btn-markpending'); if (mp) mp.disabled = (b.pending || 0) === 0;
        const sp = document.getElementById('cnt-skip-pending'); if (sp) sp.textContent = skipN;
        const spb = document.getElementById('btn-skip-pending'); if (spb) spb.disabled = skipN === 0;
        const rs = document.getElementById('cnt-reopen-skipped'); if (rs) rs.textContent = b.skip || 0;
        const rsb = document.getElementById('btn-reopen-skipped'); if (rsb) rsb.disabled = (b.skip || 0) === 0;
        const bc = document.getElementById('btn-bulkcreate'); if (bc) bc.disabled = createN === 0;
        const cp = document.getElementById('btn-complete'); if (cp) cp.disabled = !s.can_complete;

        // Auto-poll only while there's live work to watch (enrichment running, or lines still in flight).
        // Once the document settles, stop the loop — operator actions refresh manually. A re-enrich/upload
        // that creates live work calls refreshSummary(), which re-arms the poll here.
        const live = awaiting > 0 || (b.pending || 0) > 0 || s.status === 'extracting' || s.status === 'uploaded';
        ensurePolling(live);
    }

    // ---- modal helpers ----
    const overlay = document.getElementById('modal-overlay');
    const mBox = overlay.querySelector('.modal');
    const mBody = document.getElementById('modal-body');
    const mActions = document.getElementById('modal-actions');
    function openModal(html, actions) {
        if (mBox) mBox.classList.remove('modal-wide');   // reset; wide is opt-in per modal
        mBody.innerHTML = html;
        mActions.innerHTML = '';
        actions.forEach(a => {
            const btn = document.createElement('button');
            btn.className = 'btn ' + (a.primary ? 'btn-primary' : '');
            btn.textContent = a.label;
            btn.onclick = a.onClick;
            mActions.appendChild(btn);
        });
        overlay.style.display = 'flex';
    }
    function closeModal() { overlay.style.display = 'none'; }

    // ---- enrichment package -> readable summary ----
    function enrichmentHtml(enr) {
        const d = enr.item_data || {};
        const bf = enr.borrowed_from;
        const noData = !enr.item_data;
        // Enrichment already happened during extraction — show its outcome, don't imply it's pending.
        let html = '<h3>Item enrichment</h3>';
        html += '<p>Enrichment: <strong>' + (noData ? 'no catalog match found' : 'done') + '</strong>' +
                ' &middot; source <strong>' + esc(enr.enrichment_source || enr.source || 'unknown') + '</strong>';
        // Only a genuine cross-supplier borrow needs sign-off before creating.
        if (bf) html += ' <span class="pill pill-yellow">borrowed — confirm before create</span>';
        html += '</p>';
        if (bf) {
            html += '<p class="ld-borrowed">Borrowed from article <strong>' + esc(bf.article_number) + '</strong>' +
                    (bf.supplier_name ? ' (' + esc(bf.supplier_name) + ')' : '') + '. Please verify the fit below.</p>';
        }
        html += '<table class="kv">';
        html += '<tr><th>Description</th><td>' + esc(d.primary_description) + '</td></tr>';
        html += '<tr><th>Fit&nbsp;for</th><td>' + esc(d.fit_for_auto) + '</td></tr>';
        html += '<tr><th>SAP group</th><td>' + esc(d.suggested_itms_grp_cod) + '</td></tr>';
        html += '<tr><th>SKU prefix</th><td>' + esc(d.suggested_sku_prefix) + '</td></tr>';
        if (d.filtered_oems && d.filtered_oems.length) html += '<tr><th>OEMs</th><td>' + esc(d.filtered_oems.join(', ')) + '</td></tr>';
        html += '</table>';
        if (d.image_url) html += '<div style="margin-top:8px;"><img src="' + esc(d.image_url) + '" alt="" class="ld-img"/></div>';
        return html;
    }

    // ---- operator "choose borrowed donor" (swap) ----
    function verdictPill(v) {
        const cls = v === 'MATCH' ? 'pill-green' : (v === 'DIFFERENT' ? 'pill-red' : 'pill-yellow');
        return '<span class="pill ' + cls + '">' + esc(v || '?') + '</span>';
    }

    async function openDonorSwapModal(row, lineId) {
        let cands;
        try {
            const r = await fetch(base + '/lines/' + lineId + '/donor-candidates', { headers: API_KEY ? { 'X-Api-Key': API_KEY } : {} });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            cands = await r.json();
        } catch (e) { alert('Could not load donor candidates: ' + e.message); return; }

        if (!cands || !cands.length) { alert('No donor candidates available for this line.'); return; }

        let html = '<h3 class="dc-title">Choose borrowed donor</h3>';
        html += '<div class="donor-head-note">Pick the article whose part best matches this line — OEM overlap ' +
                'is the strongest signal. The new SAP item keeps its own freshly-minted code; only the borrowed ' +
                'specs/OEMs change.</div>';
        html += '<div class="donor-list">';
        cands.forEach((c, i) => {
            const wrongType = c.auto_pick_eligible === false;
            const already = c.item_code ? '<span class="dc-chip dc-chip-code" title="donor is already a SAP item">' + esc(c.item_code) + '</span>' : '';
            const imgBox = c.image_url
                ? '<div class="donor-img"><img src="' + esc(c.image_url) + '" alt="" onerror="this.parentNode.classList.add(\'noimg\');this.remove();"/></div>'
                : '<div class="donor-img noimg"></div>';
            const kit = c.is_kit ? '<span class="pill pill-blue">KIT</span>' : '';

            const bits = [];
            if (c.part_component) bits.push(esc(c.part_component));
            if (c.spec_count) bits.push(c.spec_count + ' specs');
            if (c.compatible_vehicles_count) bits.push(c.compatible_vehicles_count + ' vehicles');
            if (c.categories_count) bits.push(c.categories_count + ' cat');
            const meta = bits.length ? '<div class="dc-meta">' + bits.join(' &middot; ') + '</div>' : '';

            // OEM numbers — the priority signal — as chips, with the true total + "+N more".
            const oemArr = c.oem_numbers || [];
            const oemTotal = (typeof c.oem_count === 'number') ? c.oem_count : oemArr.length;
            let oemHtml = oemArr.length
                ? oemArr.map(o => '<span class="oem-chip">' + esc(o) + '</span>').join('')
                : '<span class="dc-dim">none</span>';
            if (oemArr.length && oemTotal > oemArr.length) oemHtml += '<span class="oem-more">+' + (oemTotal - oemArr.length) + ' more</span>';

            // Aftermarket cross-references — secondary. null ⇒ unknown (show nothing / "—").
            const xref = (c.crossref_count === null || c.crossref_count === undefined) ? ''
                : '<div class="dc-xref">' + Number(c.crossref_count).toLocaleString() + ' aftermarket cross-refs</div>';

            const vCls = c.verdict === 'MATCH' ? 'v-match' : (c.verdict === 'DIFFERENT' ? 'v-diff' : 'v-unc');
            html += '<label class="dc' + (wrongType ? ' dc-wrong' : '') + '">' +
                    '<input type="radio" name="donor-pick" value="' + i + '"' + (c.is_default ? ' checked' : '') + '>' +
                    imgBox +
                    '<div class="dc-main">' +
                        '<div class="dc-top">' +
                            '<span class="dc-art">' + esc(c.article_number) + '</span>' +
                            (c.is_default ? '<span class="dc-cur">current</span>' : '') + already +
                            '<span class="dc-verdict ' + vCls + '">' + esc(c.verdict || '?') + '</span>' +
                            (wrongType ? '<span class="dc-hand" title="different part type — override only">✋</span>' : '') + kit +
                        '</div>' +
                        '<div class="dc-name">' + esc(c.name) + ' <span class="dc-sup">— ' + esc(c.supplier) + '</span></div>' +
                        meta +
                        '<div class="dc-oems"><span class="dc-oems-lbl">OEM (' + oemTotal + ')</span>' +
                            '<span class="dc-oems-wrap">' + oemHtml + '</span></div>' +
                        xref +
                    '</div>' +
                '</label>';
        });
        html += '</div>';

        openModal(html, [
            { label: 'Cancel', onClick: closeModal },
            { label: 'Use selected donor', primary: true, onClick: async () => {
                const sel = mBody.querySelector('input[name="donor-pick"]:checked');
                if (!sel) { alert('Select a donor first.'); return; }
                const c = cands[parseInt(sel.value, 10)];
                if (c.auto_pick_eligible === false &&
                    !confirm('This candidate is a different part type (' + (c.verdict || '') + '). Borrow from it anyway?')) return;
                try {
                    const res = await api('POST', '/lines/' + lineId + '/swap-donor',
                        { article_number: c.article_number, supplier: c.supplier });
                    closeModal();
                    if (res && res.review_status) setRowPill(row, res.review_status);
                    // Force the expanded enrichment panel to reload with the new donor.
                    const detail = detailRowFor(lineId);
                    if (detail) { const box = detail.querySelector('.ld-enrichment'); if (box) box.dataset.loaded = 'false'; }
                    await refreshSummary();
                } catch (e) { alert('Swap failed: ' + e.message); }
            } }
        ]);
        if (mBox) mBox.classList.add('modal-wide');   // this modal is a wide table
    }

    // ---- per-line actions (Match / Create New+enrich / Skip) ----
    document.querySelectorAll('#lines-table .actions-menu .menu button').forEach(btn => {
        btn.addEventListener('click', async () => {
            const row = btn.closest('tr');
            const lineId = row.dataset.lineId;
            const action = btn.dataset.action;
            const details = btn.closest('details'); if (details) details.open = false;
            try {
                if (action === 'automatch') {
                    const updated = await api('POST', '/lines/' + lineId + '/auto-match');
                    if (updated) setRowPill(row, updated.review_status);
                } else if (action === 'match') {
                    const sku = prompt('Manual match — enter the SAP item code (verified against the Autohub company):');
                    if (!sku) return;
                    const updated = await api('POST', '/lines/' + lineId + '/match', { item_code: sku });
                    if (updated) setRowPill(row, updated.review_status);
                } else if (action === 'skip') {
                    const updated = await api('POST', '/lines/' + lineId + '/skip');
                    if (updated) setRowPill(row, updated.review_status);
                } else if (action === 'reopen') {
                    const updated = await api('POST', '/lines/' + lineId + '/reopen');
                    if (updated) setRowPill(row, updated.review_status);
                } else if (action === 'confirm') {
                    openConfirmModal(row, lineId);
                } else if (action === 'create_new') {
                    // Enrichment already ran at extraction — Create New just marks the line for SAP
                    // creation (no re-enrichment). The explicit choice also confirms it for the gate.
                    const updated = await api('POST', '/lines/' + lineId + '/create-new', { confirmed: true });
                    if (updated) setRowPill(row, updated.review_status);
                } else if (action === 'swap_donor') {
                    await openDonorSwapModal(row, lineId);
                } else if (action === 'reenrich') {
                    await createNewFlow(row, lineId);   // explicit re-enrichment (rarely needed)
                } else if (action === 'needs_manual') {
                    const updated = await api('POST', '/lines/' + lineId + '/needs-manual');
                    if (updated) setRowPill(row, updated.review_status);
                }
                await refreshSummary();
            } catch (e) {
                alert('Action failed: ' + e.message);
            }
        });
    });

    // ---- expandable line detail + inline edit ----
    function detailRowFor(lineId) {
        return document.querySelector('#lines-table tr.detail-row[data-line-id="' + lineId + '"]');
    }

    document.querySelectorAll('#lines-table tr.line-row').forEach(row => {
        row.addEventListener('click', async (e) => {
            if (e.target.closest('[data-noexpand]')) return;   // clicks in the Actions menu don't expand
            const lineId = row.dataset.lineId;
            const detail = detailRowFor(lineId);
            if (!detail) return;
            const show = detail.style.display === 'none';
            detail.style.display = show ? '' : 'none';
            row.classList.toggle('expanded', show);
            if (show) await loadEnrichment(lineId, detail);
        });
    });

    async function loadEnrichment(lineId, detail) {
        const box = detail.querySelector('.ld-enrichment');
        if (!box || box.dataset.loaded === 'true') return;
        box.dataset.loaded = 'true';
        try {
            const r = await fetch(base + '/lines/' + lineId + '/enrichment', { headers: API_KEY ? { 'X-Api-Key': API_KEY } : {} });
            if (r.status === 204) { box.innerHTML = '<em>No enrichment data (matched directly or not yet enriched).</em>'; return; }
            if (!r.ok) throw new Error('HTTP ' + r.status);
            box.innerHTML = enrichmentHtml(await r.json());
        } catch (e) {
            box.dataset.loaded = 'false';
            box.innerHTML = '<em class="ld-error">Could not load enrichment: ' + esc(e.message) + '</em>';
        }
    }

    document.querySelectorAll('#lines-table .ld-save').forEach(btn => {
        btn.addEventListener('click', async () => {
            const detail = btn.closest('tr.detail-row');
            const lineId = detail.dataset.lineId;
            const qty = parseFloat(detail.querySelector('.ld-qty').value);
            const price = parseFloat(detail.querySelector('.ld-price').value);
            const body = {
                quantity: isFinite(qty) ? qty : null,
                unit_price_foreign: isFinite(price) ? price : null,
                description: detail.querySelector('.ld-desc').value
            };
            btn.disabled = true;
            try {
                const updated = await api('PATCH', '/lines/' + lineId, body);
                const mainRow = document.querySelector('#lines-table tr.line-row[data-line-id="' + lineId + '"]');
                if (mainRow && updated) {
                    const tds = mainRow.querySelectorAll('td');
                    // cols: 0 # · 1 art · 2 oems · 3 desc · 4 brand · 5 qty · 6 unit price · 7 line total · 8 status
                    tds[3].textContent = updated.description || '';
                    tds[5].innerHTML = (updated.quantity != null ? Number(updated.quantity).toLocaleString(undefined, { maximumFractionDigits: 3 }) : '')
                        + ' <span class="unit">' + esc(updated.unit || '') + '</span>';
                    tds[6].textContent = updated.unit_price_foreign != null ? fmtMoney(updated.unit_price_foreign) : '';
                    tds[7].textContent = updated.line_total_foreign != null ? fmtMoney(updated.line_total_foreign) : '';
                }
                const saved = detail.querySelector('.ld-saved');
                if (saved) { saved.style.display = ''; setTimeout(() => { saved.style.display = 'none'; }, 2000); }
            } catch (e) { alert('Save failed: ' + e.message); }
            finally { btn.disabled = false; }
        });
    });

    // ---- needs_confirmation: vehicle-group brand, operator picks use-existing / create-new / skip ----
    function openConfirmModal(row, lineId) {
        const tds = row.querySelectorAll('td');
        const article = tds[1].textContent.trim();
        const oems = (tds[2].getAttribute('title') || tds[2].textContent).trim();
        const brand = tds[4].textContent.trim();
        const code = row.dataset.suggestedCode || '';
        const sup = row.dataset.suggestedSupplier || '';
        const src = row.dataset.source || '';

        let html = '<h3>Confirm match — vehicle-group brand</h3>' +
            '<p>The invoice brand is a group code, not a supplier, so this match needs your confirmation.</p>' +
            '<table class="kv">' +
            '<tr><th>Brand</th><td>' + esc(brand) + '</td></tr>' +
            '<tr><th>Article</th><td>' + esc(article) + '</td></tr>' +
            '<tr><th>OEMs</th><td>' + esc(oems) + '</td></tr>' +
            '</table>';
        if (code) {
            html += '<p style="margin-top:8px;">Suggested existing SAP item: <strong>' + esc(code) + '</strong>' +
                (sup ? ' — ' + esc(sup) : '') + (src ? ' <span class="hint">(source: ' + esc(src) + ')</span>' : '') + '</p>';
        }

        const act = async (path, body, label) => {
            try {
                const u = await api('POST', '/lines/' + lineId + path, body);
                if (u) setRowPill(row, u.review_status);
                closeModal();
                await refreshSummary();
            } catch (e) { alert(label + ' failed: ' + e.message); }
        };

        const actions = [{ label: 'Cancel', onClick: closeModal }];
        if (code) actions.push({ label: 'Use ' + code, primary: true, onClick: () => act('/match', { item_code: code }, 'Match') });
        actions.push({ label: 'Create new', onClick: () => act('/create-new', { confirmed: true }, 'Create new') });
        actions.push({ label: 'Skip', onClick: () => act('/skip', undefined, 'Skip') });
        openModal(html, actions);
    }

    async function createNewFlow(row, lineId) {
        // 1) enrich; 2) auto-matched to an existing SAP item (Path C1) -> show, no create;
        //    3) failed/unmatched -> needs_manual; 4) borrowed -> confirm/reject modal;
        //    5) auto-accepted -> mark create_new.
        let resp;
        try { resp = await api('POST', '/lines/' + lineId + '/enrich'); }
        catch (e) {
            // The server has already flagged the line 'needs manual' on a hard failure.
            setRowPill(row, 'needs_manual');
            alert('Enrichment failed: ' + e.message + '\nLine flagged "needs manual".');
            await refreshSummary();
            return;
        }
        // New shape: { enrichment, routing, matched_item_code }. Tolerate the old flat shape too.
        const enr = resp.enrichment || resp;

        // Path C1 — the donor part is already a SAP item; the server auto-matched. No creation.
        if (resp.routing === 'auto_matched') {
            setRowPill(row, 'matched');
            openModal(
                '<h3>Auto-matched via OEM bridge</h3><p>This line matches an existing SAP item <strong>' +
                esc(resp.matched_item_code) + '</strong> (the donor part is already in SAP), so no new item ' +
                'will be created.</p>',
                [{ label: 'OK', primary: true, onClick: closeModal }]);
            await refreshSummary();
            return;
        }

        const confirmCreate = async () => {
            const updated = await api('POST', '/lines/' + lineId + '/create-new', { confirmed: true });
            if (updated) setRowPill(row, updated.review_status);
            closeModal();
            await refreshSummary();
        };
        const rejectManual = async () => {
            const updated = await api('POST', '/lines/' + lineId + '/reject');
            if (updated) setRowPill(row, updated.review_status);
            closeModal();
            await refreshSummary();
        };

        // No usable enrichment (failed / partial / unmatched) — server set needs_manual; tell operator.
        if (enr.status === 'failed' || !enr.item_data) {
            setRowPill(row, 'needs_manual');
            openModal(
                '<h3>No automatic enrichment</h3><p>This line could not be enriched automatically (' +
                esc(enr.status || enr.enrichment_source || enr.source || 'unmatched') +
                '). It is flagged <strong>needs manual</strong> — match it to an existing SAP item or skip it.</p>',
                [{ label: 'Close', primary: true, onClick: closeModal }]);
            await refreshSummary();
            return;
        }

        if (enr.confirmation_required) {
            openModal(enrichmentHtml(enr), [
                { label: 'Reject (needs manual)', onClick: () => rejectManual().catch(e => alert('Failed: ' + e.message)) },
                { label: 'Confirm & mark Create New', primary: true, onClick: () => confirmCreate().catch(e => alert('Failed: ' + e.message)) }
            ]);
        } else {
            // Auto-accepted (e.g. tecdoc_direct) — mark create_new without a prompt.
            await confirmCreate();
        }
    }

    // ---- banner buttons ----
    let lastAutoMatch = 0;
    document.getElementById('btn-automatch').addEventListener('click', async (e) => {
        const now = Date.now();
        if (now - lastAutoMatch < 30000) { alert('Please wait a moment before auto-matching again.'); return; }
        lastAutoMatch = now;
        e.target.disabled = true;
        try {
            const r = await api('POST', '/auto-match');
            alert('Auto-match: ' + r.newly_matched + ' newly matched, ' + r.still_pending + ' still pending. Reloading.');
            location.reload();
        } catch (err) { alert('Auto-match failed: ' + err.message); e.target.disabled = false; }
    });

    document.getElementById('btn-markpending').addEventListener('click', async () => {
        try { await api('POST', '/bulk-mark-pending-as-create-new'); location.reload(); }
        catch (err) { alert('Failed: ' + err.message); }
    });

    document.getElementById('btn-skip-pending').addEventListener('click', () => {
        const n = document.getElementById('cnt-skip-pending').textContent;
        openModal(
            '<h3>Skip pending lines</h3><p>Skip <strong>' + n + '</strong> pending / needs-manual line(s)? ' +
            'They will be marked skipped and excluded from this document\'s SAP items. ' +
            'You can reopen individual lines (Actions → Reopen) before completing review.</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Skip ' + n + ' line(s)', primary: true, onClick: async () => {
                    try { await api('POST', '/bulk-skip-pending'); location.reload(); }
                    catch (e) { alert('Skip failed: ' + e.message); }
                } }
            ]);
    });

    document.getElementById('btn-reopen-skipped').addEventListener('click', () => {
        const n = document.getElementById('cnt-reopen-skipped').textContent;
        const reopen = async (q) => {
            try { await api('POST', '/bulk-reopen-skipped' + q); location.reload(); }
            catch (e) { alert('Reopen failed: ' + e.message); }
        };
        openModal(
            '<h3>Reopen skipped lines</h3>' +
            '<p>Move <strong>' + n + '</strong> skipped line(s) back into review:</p>' +
            '<ul style="margin:6px 0 0 18px;">' +
            '<li><strong>Needs manual</strong> — you decide each line (match / create / skip).</li>' +
            '<li><strong>Re-run enrichment</strong> — re-query DGX in the background, then auto-route ' +
            '(promotional lines stay skipped). Lines show as <em>pending</em> until the worker finishes.</li>' +
            '</ul>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: '→ Needs manual', onClick: () => reopen('') },
                { label: 'Re-run enrichment', primary: true, onClick: () => reopen('?reEnrich=true') }
            ]);
    });

    document.getElementById('btn-bulkcreate').addEventListener('click', () => {
        const n = document.getElementById('cnt-createnew').textContent;
        openModal(
            '<h3>Bulk create items</h3><p>You are about to create <strong>' + n + '</strong> item(s) in SAP (including any previously failed lines, which will be retried). This is irreversible. Borrowed-enrichment lines that were not confirmed will be flagged for confirmation rather than created. Continue?</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Create ' + n + ' item(s)', primary: true, onClick: runBulkCreate }
            ]);
    });

    document.getElementById('btn-confirm-create')?.addEventListener('click', () => {
        openModal(
            '<h3>Confirm all &amp; create</h3><p>This confirms <strong>every</strong> create-new line — including ' +
            'any cross-supplier <em>borrowed</em> enrichments — without per-line review, then creates them in SAP. ' +
            'Review borrowed lines first if unsure. Continue?</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Confirm all & create', primary: true, onClick: async () => {
                    try { await api('POST', '/bulk-confirm-create-new'); }
                    catch (e) { alert('Confirm failed: ' + e.message); return; }
                    await runBulkCreate();
                } }
            ]);
    });

    async function runBulkCreate() {
        mBody.innerHTML = '<h3>Creating items…</h3>' +
            '<p id="bc-progress">Starting…</p>' +
            '<div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden;margin:8px 0;">' +
            '<div id="bc-bar" style="height:100%;width:0%;background:var(--accent,#11827a);transition:width .3s;"></div></div>' +
            '<p class="hint">Runs in the background — it continues even if you close this page or the connection drops.</p>';
        mActions.innerHTML = '';

        // Baseline: how many were already created, and how many this run is attempting.
        let baseCreated = 0, target = 0;
        try {
            const s0 = await api('GET', '/review-summary');
            const b0 = s0.by_status || {};
            baseCreated = b0.created || 0;
            target = (b0.create_new || 0) + (b0.create_failed || 0);
        } catch (e) { /* progress is best-effort */ }

        const renderProgress = (done) => {
            const prog = document.getElementById('bc-progress');
            const bar = document.getElementById('bc-bar');
            if (prog) prog.textContent = target ? ('Created ' + done + ' of ' + target + '…') : ('Created ' + done + '…');
            if (bar && target) bar.style.width = Math.min(100, Math.round(done / target * 100)) + '%';
        };
        renderProgress(0);

        const finish = (html) => {
            mBody.innerHTML = html;
            const close = document.createElement('button'); close.className = 'btn btn-primary'; close.textContent = 'Close';
            close.onclick = () => location.reload(); mActions.innerHTML = ''; mActions.appendChild(close);
        };

        // Start a BACKGROUND job (survives the proxy/client timeout), then poll: review-summary for the
        // live created-count, and the job for the final result. The create keeps running server-side even
        // if this page is closed.
        let jobId;
        try {
            const r = await api('POST', '/bulk-create-async');
            jobId = r.job_id;
        } catch (e) {
            finish('<h3>Bulk create failed to start</h3><p>' + esc(e.message) + '</p>');
            return;
        }

        const poll = setInterval(async () => {
            try {
                const s = await api('GET', '/review-summary');
                const b = s.by_status || {};
                renderProgress(Math.max(0, (b.created || 0) - baseCreated));
            } catch (e) { /* ignore transient poll errors */ }

            let job;
            try { job = await api('GET', '/bulk-create-job/' + jobId); }
            catch (e) { return; }   // transient — keep polling
            if (job.status === 'running') return;

            clearInterval(poll);
            if (job.status === 'failed') {
                finish('<h3>Bulk create failed</h3><p>' + esc(job.error || 'unknown error') + '</p>');
                return;
            }
            let html = '<h3>Bulk create complete</h3><p>Created ' + job.created + ' of ' + job.attempted + '. Needs confirmation: ' + (job.needs_confirmation || 0) + '. Failed: ' + job.failed + '.</p>';
            if (job.needs_confirmation > 0) html += '<p class="hint">Needs-confirmation lines are cross-supplier borrowed enrichments — review them, or use “Confirm all &amp; Create” to sign off and create them.</p>';
            if (job.failures && job.failures.length) {
                html += '<ul class="failure-list">';
                job.failures.forEach(f => { html += '<li><strong>' + esc(f.article_number || '?') + '</strong>: ' + esc(f.error) + '</li>'; });
                html += '</ul>';
            }
            finish(html);
        }, 2000);
    }

    document.getElementById('btn-complete').addEventListener('click', () => {
        openModal(
            '<h3>Complete review</h3><p>Mark this invoice as reviewed? All lines must be matched, created, or skipped.</p>',
            [
                { label: 'Cancel', onClick: closeModal },
                { label: 'Mark reviewed', primary: true, onClick: runComplete }
            ]);
    });

    async function runComplete() {
        try {
            await api('POST', '/complete-review');
            window.location = '/autohub/documents';
        } catch (e) {
            mBody.innerHTML = '<h3>Cannot complete review</h3><p>' + esc(e.message) + '</p>';
            const close = document.createElement('button'); close.className = 'btn'; close.textContent = 'Close'; close.onclick = closeModal;
            mActions.innerHTML = ''; mActions.appendChild(close);
        }
    }

    // Self-managing poll: refreshSummary() arms/disarms this via ensurePolling() based on whether there's
    // live work. Each tick skips the fetch while the tab is hidden (no server load on a backgrounded tab),
    // so we no longer poll review-summary forever on an idle, fully-settled document.
    let pollTimer = null;
    function ensurePolling(live) {
        if (live && pollTimer === null) {
            pollTimer = setInterval(() => { if (!document.hidden) refreshSummary(); }, 10000);
        } else if (!live && pollTimer !== null) {
            clearInterval(pollTimer);
            pollTimer = null;
        }
    }
    // Re-check immediately when the tab becomes visible again (so a settled→live change isn't missed).
    document.addEventListener('visibilitychange', () => { if (!document.hidden) refreshSummary(); });

    refreshSummary();   // initial load; arms the poll iff there's live work
})();

// ---- delete invoice (works in any document state, so it lives outside the review IIFE) ----
(function () {
    const btn = document.getElementById('btn-delete-doc');
    if (!btn) return;
    const docId = btn.dataset.docId;
    const apiKey = document.querySelector('meta[name="api-key"]')?.content || '';
    btn.addEventListener('click', async () => {
        if (!confirm('Delete this invoice and all its extracted lines? This cannot be undone. (Any SAP items already created are NOT affected.)')) return;
        btn.disabled = true;
        try {
            const r = await fetch('/api/autohub/documents/' + docId, {
                method: 'DELETE',
                headers: apiKey ? { 'X-Api-Key': apiKey } : {}
            });
            if (!r.ok) { throw new Error((await r.text()) || ('HTTP ' + r.status)); }
            window.location.href = '/autohub/documents';
        } catch (e) { alert('Delete failed: ' + e.message); btn.disabled = false; }
    });
})();
</script>

@page "/autohub/documents/upload"
@model SapOdooMiddleware.Areas.Autohub.Pages.Documents.UploadModel

<div class="page-head">
    <div>
        <h2>Upload spare-parts invoice</h2>
        <div class="sub">VIKA, Germax, or similar — extraction starts automatically</div>
    </div>
    <a class="btn" href="/autohub/documents">← Back to list</a>
</div>

@if (Model.Error is not null)
{
    <div class="error">@Model.Error</div>
}

<div class="card" style="max-width:560px;">
    <form method="post" enctype="multipart/form-data">
        <p class="card-title">Choose a PDF</p>
        <p><input type="file" name="Pdf" accept=".pdf" required /></p>
        <div class="card-actions">
            <button class="btn btn-primary" type="submit">Upload &amp; extract</button>
            <a class="btn" href="/autohub/documents">Cancel</a>
        </div>
    </form>
</div>

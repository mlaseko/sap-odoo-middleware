@page "/autohub/documents"
@model SapOdooMiddleware.Areas.Autohub.Pages.Documents.IndexModel

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <h2 style="margin:0;">Autohub — recent documents</h2>
    <a class="btn" href="/autohub/documents/upload">Upload new</a>
</div>

@if (TempData["Notice"] is string notice)
{
    <div class="notice">@notice</div>
}

@if (Model.Docs.Count == 0)
{
    <p>No invoices uploaded yet. <a href="/autohub/documents/upload">Upload your first invoice</a>.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Uploaded</th>
                <th>File</th>
                <th>Supplier</th>
                <th>Invoice #</th>
                <th>Invoice date</th>
                <th class="num">Pages</th>
                <th>Status</th>
                <th>Validation</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var d in Model.Docs)
        {
            <tr>
                <td>@d.UploadedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@d.OriginalFilename</td>
                <td>@d.SupplierName</td>
                <td>@d.InvoiceNumber</td>
                <td>@(d.InvoiceDate?.ToString("yyyy-MM-dd"))</td>
                <td class="num">@d.PageCount</td>
                <td>@d.Status</td>
                <td>@d.ValidationStatus</td>
                <td style="white-space:nowrap;">
                    <a href="/autohub/documents/@d.Id">View</a>
                    &nbsp;·&nbsp;
                    <a href="#" class="del-doc" data-doc-id="@d.Id" data-name="@(d.InvoiceNumber ?? d.OriginalFilename)" style="color:#991b1b;">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<script>
(function () {
    const apiKey = document.querySelector('meta[name="api-key"]')?.content || '';
    document.querySelectorAll('a.del-doc').forEach(a => {
        a.addEventListener('click', async (e) => {
            e.preventDefault();
            const id = a.dataset.docId;
            if (!confirm('Delete "' + (a.dataset.name || id) + '" and all its extracted lines? This cannot be undone.')) return;
            try {
                const r = await fetch('/api/autohub/documents/' + id, {
                    method: 'DELETE',
                    headers: apiKey ? { 'X-Api-Key': apiKey } : {}
                });
                if (!r.ok) { throw new Error((await r.text()) || ('HTTP ' + r.status)); }
                a.closest('tr').remove();
            } catch (err) { alert('Delete failed: ' + err.message); }
        });
    });
})();
</script>

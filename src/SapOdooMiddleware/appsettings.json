{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/middleware-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ApiKey": {
    "Key": "CHANGE_ME_dev_api_key"
  },
  "SapB1": {
    "Server": "localhost",
    "CompanyDb": "SBODemoUS",
    "UserName": "manager",
    "Password": "",
    "DbServerType": "MSSQL2016",
    "LicenseServer": "localhost:30000",
    "SLDServer": "",
    "AutoCreatePickList": true,
    "DefaultWarehouseCode": "MainWHSE"
  },
  "Odoo": {
    "BaseUrl": "https://your-instance.odoo.com",
    "Database": "your-database-name",
    "UserName": "",
    "Password": "",
    "ApiKey": "",
    "CogsJournalId": 0,
    "CogsAccountId": 0,
    "CogsClearingAccountId": 0
  },
  "WebhookQueue": {
    "Enabled": true,
    "ConnectionString": "Server=localhost;Database=SBODemoUS;Integrated Security=True;TrustServerCertificate=True",
    "PollingIntervalSeconds": 30,
    "BatchSize": 10,
    "MaxRetries": 5
  }
}

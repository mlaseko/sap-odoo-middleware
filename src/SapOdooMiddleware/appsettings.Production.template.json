{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\SapOdoo\\Logs\\app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 20971520,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\SapOdoo\\Logs\\error-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "restrictedToMinimumLevel": "Warning",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ApiKey": {
    "Key": ""
  },
  "SapB1": {
    "Server": "",
    "CompanyDb": "",
    "UserName": "",
    "Password": "",
    "DbServerType": "MSSQL2016",
    "LicenseServer": "",
    "SLDServer": "",
    "AutoCreatePickList": true,
    "DefaultWarehouseCode": "MainWHSE"
  },
  "Odoo": {
    "BaseUrl": "",
    "Database": "",
    "UserName": "",
    "Password": "",
    "ApiKey": "",
    "CogsJournalId": 0,
    "CogsAccountId": 0,
    "CogsClearingAccountId": 0
  },
  "WebhookQueue": {
    "Enabled": false,
    "ConnectionString": "",
    "PollingIntervalSeconds": 30,
    "BatchSize": 10,
    "MaxRetries": 5
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5259"
      }
    }
  }
}
